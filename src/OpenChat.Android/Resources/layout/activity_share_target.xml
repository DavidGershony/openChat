<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/share_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        android:elevation="4dp" />

    <!-- Account selector (visible when multiple accounts) -->
    <HorizontalScrollView
        android:id="@+id/account_selector_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/account_chip_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            xmlns:app="http://schemas.android.com/apk/res-auto" />
    </HorizontalScrollView>

    <!-- Share preview -->
    <TextView
        android:id="@+id/share_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:maxLines="2"
        android:ellipsize="end"
        android:background="?attr/colorSurfaceVariant" />

    <!-- Chat list in a single scrollable RecyclerView with section headers -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/share_chat_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/share_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No chats available"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone" />

</LinearLayout>

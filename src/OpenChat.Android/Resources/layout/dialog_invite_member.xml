<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Public key (npub or hex)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/invite_pubkey_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1"
            android:fontFamily="monospace"
            android:textSize="13sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Group invite link -->
    <LinearLayout
        android:id="@+id/group_link_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/group_invite_link_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textIsSelectable="true"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/copy_group_link_button"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Copy"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:paddingHorizontal="12dp"
            style="@style/Widget.Material3.Button.TextButton" />
    </LinearLayout>

    <TextView
        android:id="@+id/invite_error_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/status_error"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/invite_success_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/status_success"
        android:layout_marginTop="8dp"
        android:visibility="gone" />
</LinearLayout>

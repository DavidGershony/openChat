<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/my_profile_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Display Name -->
    <TextView
        android:id="@+id/my_display_name_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Username -->
    <TextView
        android:id="@+id/my_username_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginTop="2dp"
        android:visibility="gone" />

    <!-- About -->
    <TextView
        android:id="@+id/my_about_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

    <!-- QR Code -->
    <ImageView
        android:id="@+id/my_npub_qr"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@android:color/white"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:visibility="gone" />

    <!-- npub label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Public Key (npub)"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginTop="16dp" />

    <!-- npub row with copy button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/my_npub_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textIsSelectable="true" />

        <ImageButton
            android:id="@+id/my_copy_npub_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Copy npub"
            android:scaleType="centerInside" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Share this npub with others so they can invite you to chats"
        android:textSize="12sp"
        android:textColor="@color/text_muted"
        android:layout_marginTop="8dp" />

</LinearLayout>

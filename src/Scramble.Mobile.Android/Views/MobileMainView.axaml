<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Scramble.Presentation.ViewModels"
             xmlns:views="using:Scramble.UI.Views"
             xmlns:asyncImageLoader="using:AsyncImageLoader"
             x:Class="Scramble.MobileAndroid.Views.MobileMainView"
             x:Name="Root"
             x:DataType="vm:ShellViewModel">

    <!--
        Mobile shell for the Avalonia Android head.

        Mirrors the *body* of Scramble.UI/Views/MainWindow.axaml (Login vs. logged-in
        content) but omits desktop chrome (custom title bar, window controls) and the
        fixed two-column sidebar+content layout that doesn't fit on a phone.

        Logged-in layout: two rows.
          Row 0 — top header bar: avatar (opens account switcher), display name,
                  and action icons (new chat + settings) aligned to the right.
          Row 1 — main content: ChatListView, ChatView overlay, SettingsView overlay.

        The top header bar hides when the settings overlay is open (CurrentView != null)
        or while an active chat is open (ChatViewModel.HasChat), so its focusable
        children don't steal TAB focus from the overlay/chat content.

        Account switcher and My Profile dialog overlays are mounted at outer Grid
        scope (same as desktop) — they reuse the shared UserControls in
        Scramble.UI/Views/ so the unified Avalonia UI stays the single source of truth.

        The DataContext is ShellViewModel (set by App.OnFrameworkInitializationCompleted).
    -->

    <Grid Background="{DynamicResource BackgroundDarkBrush}">

        <!-- Logged-in view (only when IsLoggedIn).
             IsVisible binds against the outer ShellViewModel BEFORE DataContext is
             reassigned to MainViewModel for descendants — use a relative binding so
             the compiled-bindings type checker doesn't look up IsLoggedIn on
             MainViewModel. -->
        <Grid IsVisible="{Binding #Root.DataContext.IsLoggedIn}"
              DataContext="{Binding MainViewModel}"
              x:DataType="vm:MainViewModel"
              RowDefinitions="Auto,*">

            <!-- Top header bar: avatar (tap to open account switcher), display name,
                 and action icons (new chat + settings) aligned to the right.
                 Hidden when chat is open or when settings overlay is shown so its
                 controls don't capture focus underneath. -->
            <Panel Grid.Row="0"
                   IsVisible="{Binding CurrentView, Converter={x:Static ObjectConverters.IsNull}}">
                <Panel IsVisible="{Binding !ChatViewModel.HasChat}">
                    <Border Padding="12,8" Background="{DynamicResource BackgroundLightBrush}">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                            <!-- Avatar (clickable - opens account switcher) -->
                            <Button x:Name="AvatarButton" Grid.Column="0" Classes="icon"
                                    Click="AvatarButton_Click"
                                    Padding="0" CornerRadius="18">
                                <Panel Width="36" Height="36">
                                    <Border Width="36" Height="36" CornerRadius="18"
                                            Background="{DynamicResource NostrPurpleBrush}"
                                            IsVisible="{Binding MyPictureUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}">
                                        <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"
                                                  Width="20" Height="20" Foreground="White" />
                                    </Border>
                                    <Border Width="36" Height="36" CornerRadius="18" ClipToBounds="True"
                                            IsVisible="{Binding MyPictureUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <Image asyncImageLoader:ImageLoader.Source="{Binding MyPictureUrl}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                </Panel>
                            </Button>
                            <!-- Name or loading indicator -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" MaxWidth="240" Margin="10,0,0,0">
                                <TextBlock Text="{Binding HeaderDisplayName}" FontSize="16" FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis"
                                           IsVisible="{Binding !IsHeaderLoading}" />
                                <TextBlock Text="Loading..." FontSize="12" Classes="muted"
                                           IsVisible="{Binding IsHeaderLoading}" />
                            </StackPanel>
                            <!-- New Chat icon button -->
                            <Button Grid.Column="2" Classes="icon"
                                    Command="{Binding ChatListViewModel.NewChatCommand}"
                                    ToolTip.Tip="New Chat"
                                    Padding="8" Margin="4,0">
                                <PathIcon Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"
                                          Width="22" Height="22"
                                          Foreground="{DynamicResource ForegroundBrush}" />
                            </Button>
                            <!-- Link Device icon button -->
                            <Button Grid.Column="3" Classes="icon"
                                    Command="{Binding ChatListViewModel.AddBotCommand}"
                                    ToolTip.Tip="Link Device"
                                    Padding="8" Margin="0">
                                <PathIcon Data="M80-160v-120h80v-440q0-33 23.5-56.5T240-800h600v80H240v440h240v120H80Zm520 0q-17 0-28.5-11.5T560-200v-400q0-17 11.5-28.5T600-640h240q17 0 28.5 11.5T880-600v400q0 17-11.5 28.5T840-160H600Zm40-120h160v-280H640v280Zm0 0h160-160Z"
                                          Width="22" Height="22"
                                          Foreground="{DynamicResource ForegroundBrush}" />
                            </Button>
                            <!-- Settings icon button (3 vertical dots) -->
                            <Button Grid.Column="4" Classes="icon"
                                    Command="{Binding ShowSettingsCommand}"
                                    ToolTip.Tip="Settings"
                                    Padding="8" Margin="0,0,4,0">
                                <PathIcon Data="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"
                                          Width="22" Height="22"
                                          Foreground="{DynamicResource ForegroundBrush}" />
                            </Button>
                        </Grid>
                    </Border>
                </Panel>
            </Panel>

            <!-- Main content -->
            <Grid Grid.Row="1">
                <!-- Chat list (default view).
                     Outer Panel hides the list whenever the settings overlay is open (CurrentView != null);
                     inner IsVisible additionally hides it when an active chat is open.
                     This stops the list's focusable controls from cycling under TAB when the overlay is shown. -->
                <Panel IsVisible="{Binding CurrentView, Converter={x:Static ObjectConverters.IsNull}}">
                    <views:ChatListView DataContext="{Binding ChatListViewModel}"
                                        IsVisible="{Binding !$parent[Grid].DataContext.ChatViewModel.HasChat}" />
                </Panel>

                <!-- Active chat overlay -->
                <views:ChatView DataContext="{Binding ChatViewModel}"
                                IsVisible="{Binding HasChat}" />

                <!-- Settings overlay (when CurrentView is set) -->
                <views:SettingsView DataContext="{Binding SettingsViewModel}"
                                    IsVisible="{Binding $parent[Grid].DataContext.CurrentView, Converter={x:Static ObjectConverters.IsNotNull}}" />
            </Grid>

        </Grid>

        <!-- Login view (only when not logged in). DataContext is reassigned to
             LoginViewModel so IsVisible must reach back to ShellViewModel. -->
        <views:LoginView DataContext="{Binding LoginViewModel}"
                         IsVisible="{Binding #Root.DataContext.IsLoggedIn, Converter={x:Static BoolConverters.Not}}" />

        <!-- New Chat dialog overlay. Mirrors the desktop overlay at MainWindow.axaml; both shells
             render the same NewChatDialogView UserControl. Placed at outer Grid scope so the dim
             backdrop covers the entire screen. -->
        <ContentControl DataContext="{Binding #Root.DataContext.MainViewModel.ChatListViewModel}"
                        x:DataType="vm:ChatListViewModel"
                        IsVisible="{Binding ShowNewChatDialog, FallbackValue=False}">
            <views:NewChatDialogView />
        </ContentControl>

        <!-- Link Device dialog overlay. Mirrors the desktop overlay at MainWindow.axaml. -->
        <Border DataContext="{Binding #Root.DataContext.MainViewModel.ChatListViewModel}"
                x:DataType="vm:ChatListViewModel"
                IsVisible="{Binding ShowAddBotDialog, FallbackValue=False}"
                Background="#80000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Classes="card"
                    Background="{DynamicResource BackgroundCardBrush}"
                    CornerRadius="16"
                    Padding="20"
                    Margin="16"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch">
                <Panel>
                    <!-- Form content (hidden during connecting) -->
                    <StackPanel Spacing="14"
                                IsVisible="{Binding !CreateBotChatCommand.IsExecuting^}">
                        <!-- Header -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Link Device"
                                       FontSize="20" FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1" Classes="icon"
                                    Command="{Binding CancelAddBotCommand}"
                                    ToolTip.Tip="Close">
                                <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                          Width="20" Height="20" />
                            </Button>
                        </Grid>

                        <!-- Device Public Key Input -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Device Public Key" Classes="secondary" FontSize="13" />
                            <TextBox Text="{Binding BotNpub}"
                                     PlaceholderText="npub1..."
                                     AcceptsReturn="False" />
                            <TextBlock Text="Enter the npub of a bot or IoT device. Messages use NIP-17 encrypted DMs."
                                       Classes="muted" FontSize="11" TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- Relay Selection -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Relay" Classes="secondary" FontSize="13" />

                            <RadioButton Content="Find user relay (NIP-65)"
                                         IsChecked="{Binding BotRelayModeNip65}"
                                         GroupName="BotRelay" />
                            <RadioButton Content="Select from connected relays"
                                         IsChecked="{Binding BotRelayModeList}"
                                         GroupName="BotRelay" />
                            <RadioButton Content="Add relay manually"
                                         IsChecked="{Binding BotRelayModeManual}"
                                         GroupName="BotRelay" />

                            <!-- NIP-65 panel -->
                            <StackPanel Spacing="4" IsVisible="{Binding BotRelayModeNip65}">
                                <Button Classes="secondary" Content="Look up relays"
                                        Command="{Binding LookupBotNip65Command}"
                                        Padding="12,4" FontSize="12"
                                        HorizontalAlignment="Left" />
                                <ProgressBar IsIndeterminate="True" Height="2"
                                             IsVisible="{Binding IsFetchingNip65}"
                                             Foreground="{DynamicResource NostrPurpleBrush}" />
                                <TextBlock Text="{Binding Nip65Status}"
                                           FontSize="12" TextWrapping="Wrap"
                                           IsVisible="{Binding Nip65Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                <ItemsControl ItemsSource="{Binding BotNip65Relays}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Url}" IsChecked="{Binding IsChecked}"
                                                      FontSize="12" Margin="0,1" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Select from list panel -->
                            <StackPanel Spacing="4" IsVisible="{Binding BotRelayModeList}">
                                <ItemsControl ItemsSource="{Binding BotAvailableRelays}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Url}" IsChecked="{Binding IsChecked}"
                                                      FontSize="12" Margin="0,1" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No relays connected."
                                           Classes="muted" FontSize="12"
                                           IsVisible="{Binding !BotAvailableRelays.Count}" />
                            </StackPanel>

                            <!-- Manual relay panel -->
                            <StackPanel Spacing="4" IsVisible="{Binding BotRelayModeManual}">
                                <TextBox Text="{Binding BotManualRelay}"
                                         PlaceholderText="wss://relay.example.com"
                                         AcceptsReturn="False" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Error Message -->
                        <TextBlock Text="{Binding AddBotError}"
                                   Foreground="{DynamicResource StatusErrorBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding AddBotError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <!-- Buttons -->
                        <Grid ColumnDefinitions="*,12,*" Margin="0,8,0,0">
                            <Button Grid.Column="0"
                                    Classes="secondary"
                                    Content="Cancel"
                                    Command="{Binding CancelAddBotCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" />
                            <Button Grid.Column="2"
                                    Classes="primary"
                                    Content="Link"
                                    Command="{Binding CreateBotChatCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <!-- Progress overlay (shown while connecting) -->
                    <StackPanel IsVisible="{Binding CreateBotChatCommand.IsExecuting^}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="16"
                                Margin="40">
                        <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                     Foreground="{DynamicResource NostrPurpleBrush}" />
                        <TextBlock Text="Linking device..."
                                   FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="This may take a moment"
                                   Classes="muted" FontSize="12"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Panel>
            </Border>
        </Border>

        <!-- Account switcher overlay (shared with desktop MainWindow). Gated on
             ShellViewModel.ShowAccountSwitcher. -->
        <ContentControl IsVisible="{Binding ShowAccountSwitcher, FallbackValue=False}">
            <views:AccountSwitcherView />
        </ContentControl>

        <!-- My Profile dialog overlay (shared with desktop MainWindow). Gated on
             MainViewModel.ShowMyProfileDialog. -->
        <ContentControl DataContext="{Binding #Root.DataContext.MainViewModel}"
                        x:DataType="vm:MainViewModel"
                        IsVisible="{Binding ShowMyProfileDialog, FallbackValue=False}">
            <views:MyProfileDialogView />
        </ContentControl>
    </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Scramble.Presentation.ViewModels"
             xmlns:sys="using:System"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="700"
             x:Class="Scramble.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <Grid RowDefinitions="Auto,*">
        <!-- Fixed Header -->
        <Border Grid.Row="0" Padding="24,16" Background="{DynamicResource BackgroundDarkBrush}">
            <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0" Classes="icon" Margin="0,0,12,0"
                        Command="{Binding BackCommand}"
                        ToolTip.Tip="Back to chats">
                    <PathIcon Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"
                              Width="24" Height="24" />
                </Button>
                <TextBlock Grid.Column="1" Text="Settings" Classes="header" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
            </Grid>
        </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" Margin="24">

            <!-- Theme Section -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Theme" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Text="Customize the app appearance" Classes="secondary" />
                    <ComboBox SelectedIndex="{Binding SelectedThemeIndex}"
                              HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Nostr" />
                        <ComboBoxItem Content="Golden Axe" />
                        <ComboBoxItem Content="Cyber Teal" />
                        <ComboBoxItem Content="AMOLED Black" />
                        <ComboBoxItem Content="AMOLED Purple" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Profile Section (hidden when using external signer) -->
            <Border Classes="card" IsVisible="{Binding CanEditProfile}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Profile" FontWeight="SemiBold" FontSize="16" />

                    <!-- Avatar -->
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Border Width="80" Height="80" CornerRadius="40"
                                Background="{DynamicResource NostrPurpleBrush}">
                            <TextBlock Text="U" FontSize="32" FontWeight="SemiBold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <Button Classes="secondary" Content="Change Avatar" />
                            <TextBlock Text="PNG or JPG, max 2MB" Classes="muted" FontSize="12" />
                        </StackPanel>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,16,*" RowDefinitions="Auto,12,Auto">
                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                            <TextBlock Text="Display Name" Classes="muted" FontSize="12" />
                            <TextBox Text="{Binding DisplayName}" PlaceholderText="Your display name" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Grid.Row="0" Spacing="4">
                            <TextBlock Text="Username" Classes="muted" FontSize="12" />
                            <TextBox Text="{Binding Username}" PlaceholderText="@username" />
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="3" Spacing="4">
                            <TextBlock Text="About" Classes="muted" FontSize="12" />
                            <TextBox Text="{Binding About}" PlaceholderText="Tell others about yourself..."
                                     AcceptsReturn="True" TextWrapping="Wrap" Height="80" />
                        </StackPanel>
                    </Grid>

                    <Button Classes="primary" Content="Save Profile" Command="{Binding SaveProfileCommand}"
                            HorizontalAlignment="Left" />

                    <!-- Publish confirmation dialog -->
                    <Border Background="{DynamicResource BackgroundLightBrush}" CornerRadius="8"
                            Padding="16" Margin="0,8,0,0"
                            IsVisible="{Binding ShowPublishConfirmation}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Publish profile to relays?" FontWeight="SemiBold" />
                            <TextBlock Text="This will update your profile details on every Nostr client that reads your metadata."
                                       TextWrapping="Wrap" Classes="muted" FontSize="13" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="primary" Content="Publish"
                                        Command="{Binding ConfirmPublishProfileCommand}" />
                                <Button Classes="secondary" Content="Skip"
                                        Command="{Binding CancelPublishProfileCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Publish status -->
                    <TextBlock Text="{Binding PublishProfileStatus}"
                               IsVisible="{Binding PublishProfileStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Classes="muted" FontSize="13" Margin="0,4,0,0" />
                    <TextBlock Text="Publishing..."
                               IsVisible="{Binding IsPublishingProfile}"
                               Classes="muted" FontSize="13" />
                </StackPanel>
            </Border>

            <!-- ── Add Relays ── -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Add Relays" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Text="Select relays from the list or enter a custom domain"
                               Classes="secondary" FontSize="13" />

                    <!-- Popular relays picker -->
                    <ItemsControl ItemsSource="{Binding PopularRelays}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RelayPickerItem">
                                <CheckBox IsChecked="{Binding IsSelected}" Margin="0,2">
                                    <TextBlock Text="{Binding Domain}" FontFamily="Consolas,monospace" FontSize="13" />
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Custom relay input -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0" Text="wss://" FontFamily="Consolas,monospace"
                                   FontSize="13" VerticalAlignment="Center" Opacity="0.5" Margin="0,0,2,0" />
                        <TextBox Grid.Column="1" Text="{Binding CustomRelayDomain}"
                                 PlaceholderText="custom.relay.com" FontSize="13">
                            <TextBox.KeyBindings>
                                <KeyBinding Gesture="Enter" Command="{Binding AddCustomRelayCommand}" />
                            </TextBox.KeyBindings>
                        </TextBox>
                        <Button Grid.Column="2" Classes="secondary" Content="Add Custom"
                                Command="{Binding AddCustomRelayCommand}" Margin="8,0,0,0" />
                    </Grid>

                    <!-- Target list checkboxes -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Add to:" FontSize="13" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox IsChecked="{Binding AddToGeneral}" Content="General" FontSize="13" />
                            <CheckBox IsChecked="{Binding AddToDm}" Content="DM (NIP-17)" FontSize="13" />
                            <CheckBox IsChecked="{Binding AddToKp}" Content="KeyPackage" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Add selected button -->
                    <Button Classes="primary" Content="Add Selected Relays"
                            Command="{Binding AddPickedRelaysCommand}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- ── General Relays ── -->
            <Border Classes="card" Padding="0">
                <StackPanel>
                    <Button Classes="icon" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="16,12" Command="{Binding ToggleGeneralRelaySectionCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="M480 -120 160 -440l64 -64 256 256 256 -256 64 64 -320 320Z"
                                      Width="14" Height="14" IsVisible="{Binding ShowGeneralRelaySection}" />
                            <PathIcon Data="M560 -240 320 -480l64 -64 256 256 256 -256 64 64 -400 400Z"
                                      Width="14" Height="14" IsVisible="{Binding !ShowGeneralRelaySection}">
                                <PathIcon.RenderTransform>
                                    <RotateTransform Angle="-90" />
                                </PathIcon.RenderTransform>
                            </PathIcon>
                            <TextBlock Text="General Relays" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="{Binding Relays.Count, StringFormat='({0})'}"
                                       Classes="muted" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <StackPanel IsVisible="{Binding ShowGeneralRelaySection}" Spacing="8" Margin="16,0,16,16">
                        <TextBlock Text="Your connected relays for sending and receiving messages"
                                   Classes="muted" FontSize="11" TextWrapping="Wrap" />

                        <ItemsControl x:Name="RelaysItemsControl" ItemsSource="{Binding Relays}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RelayViewModel">
                                    <Border Background="{DynamicResource SurfaceSecondaryBrush}"
                                            CornerRadius="6" Padding="10,6" Margin="0,2">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                            <Panel Grid.Column="0" Width="10" Height="10" Margin="0,0,8,0">
                                                <Ellipse Fill="{DynamicResource StatusOnlineBrush}" IsVisible="{Binding IsConnected}" />
                                                <Ellipse Fill="{DynamicResource StatusErrorBrush}" IsVisible="{Binding !IsConnected}" />
                                            </Panel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Url}" FontFamily="Consolas" FontSize="12" />
                                                <TextBlock Text="{Binding Error}" Classes="muted" FontSize="11"
                                                           IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Classes="icon" Margin="4,0"
                                                    Command="{ReflectionBinding DataContext.CycleRelayUsageCommand, ElementName=RelaysItemsControl}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="Toggle relay usage: Read &amp; Write / Read / Write">
                                                <TextBlock Text="{Binding UsageLabel}" FontSize="11" Opacity="0.7" />
                                            </Button>
                                            <Button Grid.Column="3" Classes="icon"
                                                    Command="{ReflectionBinding DataContext.RemoveRelayCommand, ElementName=RelaysItemsControl}"
                                                    CommandParameter="{Binding}">
                                                <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                                          Width="14" Height="14" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Reconnect only offline relays -->
                        <Button Classes="secondary" Content="Reconnect offline relays"
                                Command="{Binding ReconnectDisconnectedCommand}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── DM Relays (kind 10050) ── -->
            <Border Classes="card" Padding="0">
                <StackPanel>
                    <Button Classes="icon" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="16,12" Command="{Binding ToggleDmRelaySectionCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="M480 -120 160 -440l64 -64 256 256 256 -256 64 64 -320 320Z"
                                      Width="14" Height="14" IsVisible="{Binding ShowDmRelaySection}" />
                            <PathIcon Data="M560 -240 320 -480l64 -64 256 256 256 -256 64 64 -400 400Z"
                                      Width="14" Height="14" IsVisible="{Binding !ShowDmRelaySection}">
                                <PathIcon.RenderTransform>
                                    <RotateTransform Angle="-90" />
                                </PathIcon.RenderTransform>
                            </PathIcon>
                            <TextBlock Text="DM Relays (NIP-17)" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="{Binding DmRelays.Count, StringFormat='({0})'}"
                                       Classes="muted" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <StackPanel IsVisible="{Binding ShowDmRelaySection}" Spacing="8" Margin="16,0,16,16">
                        <TextBlock Text="Relays where others send you direct messages (kind 10050). When empty, your general relay list is used."
                                   Classes="muted" FontSize="11" TextWrapping="Wrap" />

                        <ItemsControl x:Name="DmRelaysItemsControl" ItemsSource="{Binding DmRelays}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="sys:String">
                                    <Border Background="{DynamicResource SurfaceSecondaryBrush}"
                                            CornerRadius="6" Padding="10,6" Margin="0,2">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="1" Classes="icon"
                                                    Command="{ReflectionBinding DataContext.RemoveDmRelayCommand, ElementName=DmRelaysItemsControl}"
                                                    CommandParameter="{Binding}">
                                                <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                                          Width="14" Height="14" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── KeyPackage Relays (kind 10051) ── -->
            <Border Classes="card" Padding="0">
                <StackPanel>
                    <Button Classes="icon" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="16,12" Command="{Binding ToggleKpRelaySectionCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="M480 -120 160 -440l64 -64 256 256 256 -256 64 64 -320 320Z"
                                      Width="14" Height="14" IsVisible="{Binding ShowKpRelaySection}" />
                            <PathIcon Data="M560 -240 320 -480l64 -64 256 256 256 -256 64 64 -400 400Z"
                                      Width="14" Height="14" IsVisible="{Binding !ShowKpRelaySection}">
                                <PathIcon.RenderTransform>
                                    <RotateTransform Angle="-90" />
                                </PathIcon.RenderTransform>
                            </PathIcon>
                            <TextBlock Text="KeyPackage Relays" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="{Binding KpRelays.Count, StringFormat='({0})'}"
                                       Classes="muted" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <StackPanel IsVisible="{Binding ShowKpRelaySection}" Spacing="8" Margin="16,0,16,16">
                        <TextBlock Text="Relays where your MLS KeyPackages are published (kind 10051). When empty, your general relay list is used."
                                   Classes="muted" FontSize="11" TextWrapping="Wrap" />

                        <ItemsControl x:Name="KpRelaysItemsControl" ItemsSource="{Binding KpRelays}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="sys:String">
                                    <Border Background="{DynamicResource SurfaceSecondaryBrush}"
                                            CornerRadius="6" Padding="10,6" Margin="0,2">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="1" Classes="icon"
                                                    Command="{ReflectionBinding DataContext.RemoveKpRelayCommand, ElementName=KpRelaysItemsControl}"
                                                    CommandParameter="{Binding}">
                                                <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                                          Width="14" Height="14" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Published Relay List (NIP-65) ── -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Published Relay List (NIP-65)" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Text="Your relay preferences as published on the Nostr network (kind 10002)"
                               Classes="secondary" FontSize="13" TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="secondary" Content="Fetch from Network"
                                Command="{Binding FetchNip65Command}"
                                IsEnabled="{Binding !IsFetchingNip65}" />
                        <Button Classes="primary" Content="Publish Relay List"
                                Command="{Binding PublishRelayListCommand}" />
                    </StackPanel>

                    <!-- Fetch status -->
                    <TextBlock Text="{Binding Nip65Status}"
                               IsVisible="{Binding Nip65Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Classes="muted" FontSize="12" />

                    <!-- Publish status -->
                    <TextBlock Text="{Binding PublishRelayListStatus}"
                               IsVisible="{Binding PublishRelayListStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Classes="muted" FontSize="12" />

                    <!-- NIP-65 relay list display -->
                    <ItemsControl ItemsSource="{Binding Nip65Relays}"
                                  IsVisible="{Binding Nip65Relays.Count}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RelayViewModel">
                                <Border Background="{DynamicResource SurfaceSecondaryBrush}"
                                        CornerRadius="6" Padding="10,6" Margin="0,2">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Url}"
                                                   FontFamily="Consolas" FontSize="12"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding UsageLabel}"
                                                   FontSize="11" Opacity="0.6"
                                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Private Relay (optional) -->
                        <StackPanel Spacing="6" Margin="0,8,0,0">
                            <TextBlock Text="Private Relay (optional)" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="A highly trusted relay that supplements your other relays. Used for device sync and KeyPackage discovery. Does not replace your normal relays."
                                       Classes="muted" FontSize="11" TextWrapping="Wrap" />

                            <!-- Display mode -->
                            <Grid ColumnDefinitions="*,Auto"
                                  IsVisible="{Binding !IsEditingSyncRelay}">
                                <TextBlock Grid.Column="0" FontSize="13" VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="wss://{0}">
                                            <Binding Path="SyncRelayDomain" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                    <TextBlock.IsVisible>
                                        <Binding Path="SyncRelayDomain"
                                                 Converter="{x:Static StringConverters.IsNotNullOrEmpty}" />
                                    </TextBlock.IsVisible>
                                </TextBlock>
                                <TextBlock Grid.Column="0" Text="Not configured"
                                           Classes="muted" FontSize="13" VerticalAlignment="Center"
                                           IsVisible="{Binding SyncRelayDomain, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                <Button Grid.Column="1" Classes="secondary" Content="Edit" Padding="8,4"
                                        Command="{Binding EditSyncRelayCommand}" />
                            </Grid>

                            <!-- Edit mode -->
                            <StackPanel Spacing="6"
                                        IsVisible="{Binding IsEditingSyncRelay}">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Text="wss://" FontSize="13"
                                               VerticalAlignment="Center" Opacity="0.6" Margin="0,0,2,0" />
                                    <TextBox Grid.Column="1" Text="{Binding SyncRelayDomain}"
                                             PlaceholderText="relay.example.com" FontSize="13" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button Classes="primary" Content="Save" Padding="12,4"
                                            Command="{Binding SaveSyncRelayCommand}" />
                                    <Button Classes="secondary" Content="Cancel" Padding="12,4"
                                            Command="{Binding CancelEditSyncRelayCommand}" />
                                </StackPanel>
                                <TextBlock Text="{Binding SyncRelayStatus}"
                                           Classes="muted" FontSize="11"
                                           IsVisible="{Binding SyncRelayStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Show Private Notes toggle -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Show Private Notes in chat list" FontSize="13" />
                                <TextBlock Text="Pins the device-sync group as &quot;Private Notes&quot; at the top of your chat list"
                                           Classes="muted" FontSize="11" TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowDeviceSyncChat}"
                                           VerticalAlignment="Center" />
                        </Grid>

                        <!-- Dummy KeyPackage obfuscation toggle -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Device count obfuscation" FontSize="13" />
                                <TextBlock Text="Publishes dummy KeyPackages to your private relay to mask how many devices you have. Requires a private relay to be configured."
                                           Classes="muted" FontSize="11" TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding DummyKeyPackagesEnabled}"
                                           VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
            </Border>

            <!-- Marmot Protocol Section -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Marmot Protocol" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Text="MLS (Messaging Layer Security) provides end-to-end encryption for group chats. Publish a KeyPackage so others can invite you to groups."
                               Classes="secondary" TextWrapping="Wrap" FontSize="13" />

                    <!-- Publish Key Package -->
                    <StackPanel Spacing="8">
                        <Button Classes="primary" Content="Publish Key Package"
                                Command="{Binding PublishKeyPackageCommand}"
                                IsEnabled="{Binding !IsPublishingKeyPackage}"
                                HorizontalAlignment="Left" />

                        <!-- Status Message -->
                        <Border IsVisible="{Binding KeyPackageStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Background="{DynamicResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon IsVisible="{Binding KeyPackageSuccess}"
                                          Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                          Width="18" Height="18" Foreground="{DynamicResource StatusOnlineBrush}" />
                                <PathIcon IsVisible="{Binding !KeyPackageSuccess}"
                                          Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"
                                          Width="18" Height="18" Foreground="{DynamicResource StatusWarningBrush}" />
                                <TextBlock Text="{Binding KeyPackageStatus}"
                                           FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Loading Indicator -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding IsPublishingKeyPackage}">
                            <TextBlock Text="Publishing..." Classes="muted" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Audit Key Packages -->
                    <StackPanel Spacing="8">
                        <Button Classes="secondary" Content="Audit Key Packages"
                                Command="{Binding AuditKeyPackagesCommand}"
                                IsEnabled="{Binding !IsAuditingKeyPackages}"
                                HorizontalAlignment="Left" />

                        <Border IsVisible="{Binding AuditStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Background="{DynamicResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12">
                            <TextBlock Text="{Binding AuditStatus}"
                                       FontSize="13" TextWrapping="Wrap" />
                        </Border>

                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding IsAuditingKeyPackages}">
                            <TextBlock Text="Auditing..." Classes="muted" FontSize="13" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── My Devices ── -->
            <Border Classes="card" Padding="0">
                <StackPanel>
                    <Button Classes="icon" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="16,12" Command="{Binding ToggleDeviceSectionCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="M480 -120 160 -440l64 -64 256 256 256 -256 64 64 -320 320Z"
                                      Width="14" Height="14" IsVisible="{Binding ShowDeviceSection}" />
                            <PathIcon Data="M560 -240 320 -480l64 -64 256 256 256 -256 64 64 -400 400Z"
                                      Width="14" Height="14" IsVisible="{Binding !ShowDeviceSection}">
                                <PathIcon.RenderTransform>
                                    <RotateTransform Angle="-90" />
                                </PathIcon.RenderTransform>
                            </PathIcon>
                            <TextBlock Text="My Devices" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="{Binding MyDevices.Count, StringFormat='({0})'}"
                                       Classes="muted" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <StackPanel IsVisible="{Binding ShowDeviceSection}" Spacing="8" Margin="16,0,16,16">
                        <TextBlock Text="Devices linked to your Nostr identity. Each device has a unique MLS KeyPackage slot on relays."
                                   Classes="muted" FontSize="11" TextWrapping="Wrap" />

                        <!-- This device's slot ID -->
                        <Border Background="{DynamicResource SurfaceSecondaryBrush}"
                                CornerRadius="6" Padding="12,8"
                                IsVisible="{Binding LocalSlotId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="This Device Slot ID" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock Text="{Binding LocalSlotId}" FontFamily="Consolas" FontSize="11"
                                           TextWrapping="Wrap" Opacity="0.85" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="No slot ID yet — publish a KeyPackage first"
                                   Classes="muted" FontSize="12"
                                   IsVisible="{Binding LocalSlotId, Converter={x:Static StringConverters.IsNullOrEmpty}}" />

                        <Button Classes="secondary" Content="Refresh from Relays"
                                Command="{Binding FetchDevicesCommand}"
                                IsEnabled="{Binding !IsFetchingDevices}"
                                HorizontalAlignment="Left" />

                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding IsFetchingDevices}">
                            <TextBlock Text="Fetching..." Classes="muted" FontSize="13" />
                        </StackPanel>

                        <TextBlock Text="{Binding DeviceStatus}"
                                   Classes="muted" FontSize="12"
                                   IsVisible="{Binding DeviceStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <ItemsControl x:Name="DevicesItemsControl" ItemsSource="{Binding MyDevices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:DeviceViewModel">
                                    <Border Background="{DynamicResource SurfaceSecondaryBrush}"
                                            CornerRadius="6" Padding="10,8" Margin="0,2">
                                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                            <!-- Device status dot -->
                                            <Panel Grid.Column="0" Grid.RowSpan="2" Width="10" Height="10"
                                                   Margin="0,0,10,0" VerticalAlignment="Center">
                                                <Ellipse Fill="{DynamicResource StatusOnlineBrush}" IsVisible="{Binding IsThisDevice}" />
                                                <Ellipse Fill="{DynamicResource StatusErrorBrush}" IsVisible="{Binding IsLost}" />
                                                <Ellipse Fill="{DynamicResource TextMutedBrush}">
                                                    <Ellipse.IsVisible>
                                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                            <Binding Path="!IsThisDevice" />
                                                            <Binding Path="!IsLost" />
                                                        </MultiBinding>
                                                    </Ellipse.IsVisible>
                                                </Ellipse>
                                            </Panel>

                                            <!-- Slot ID + label -->
                                            <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding ShortSlotId}" FontFamily="Consolas" FontSize="12" />
                                                <Border Background="{DynamicResource NostrPurpleBrush}"
                                                        CornerRadius="4" Padding="6,1"
                                                        IsVisible="{Binding IsThisDevice}">
                                                    <TextBlock Text="This device" FontSize="10" Foreground="White" />
                                                </Border>
                                                <Border Background="{DynamicResource StatusErrorBrush}"
                                                        CornerRadius="4" Padding="6,1"
                                                        IsVisible="{Binding IsLost}">
                                                    <TextBlock Text="Lost" FontSize="10" Foreground="White" />
                                                </Border>
                                            </StackPanel>

                                            <!-- Date -->
                                            <TextBlock Grid.Column="1" Grid.Row="1"
                                                       Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                       Classes="muted" FontSize="11" />

                                            <!-- Actions column -->
                                            <StackPanel Grid.Column="2" Grid.RowSpan="2"
                                                        VerticalAlignment="Center" Orientation="Horizontal" Spacing="6">
                                                <!-- Unsupported indicator -->
                                                <TextBlock Text="Unsupported" FontSize="10"
                                                           Foreground="{DynamicResource StatusErrorBrush}"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding !IsSupported}" />
                                                <!-- Mark as Lost button: only for peer devices not already lost -->
                                                <Button Classes="secondary" FontSize="10" Padding="6,2"
                                                        Content="Mark as Lost"
                                                        Command="{ReflectionBinding DataContext.MarkDeviceAsLostCommand, ElementName=DevicesItemsControl}"
                                                        CommandParameter="{Binding}">
                                                    <Button.IsVisible>
                                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                            <Binding Path="!IsThisDevice" />
                                                            <Binding Path="!IsLost" />
                                                        </MultiBinding>
                                                    </Button.IsVisible>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Privacy Section -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Privacy" FontWeight="SemiBold" FontSize="16" />

                    <!-- MIP-04 Media Loading Toggle -->
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Enable media loading (MIP-04)" FontSize="14" />
                                <TextBlock Text="Load and decrypt images shared in group chats"
                                           Classes="muted" FontSize="12" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsMip04Enabled}"
                                          VerticalAlignment="Center" />
                        </Grid>

                        <Border Background="{DynamicResource WarningBgBrush}" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"
                                              Width="16" Height="16" Foreground="{DynamicResource StatusWarningBrush}" />
                                    <TextBlock Text="Risk: Medium" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{DynamicResource StatusWarningBrush}" />
                                </StackPanel>
                                <TextBlock Text="Enabling media loading allows the app to download files from URLs in messages. This exposes your IP address to the hosting server and increases attack surface. Only enable if you trust your group members."
                                           TextWrapping="Wrap" FontSize="12" Classes="muted" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Dependency warning -->
                    <Border IsVisible="{Binding Mip04DependencyWarning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Background="{DynamicResource ErrorBgBrush}" CornerRadius="8" Padding="12" Margin="0,4,0,0">
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                          Width="16" Height="16" Foreground="{DynamicResource StatusErrorBrush}" />
                                <TextBlock Text="Missing dependency" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource StatusErrorBrush}" />
                            </StackPanel>
                            <TextBlock Text="{Binding Mip04DependencyWarning}"
                                       TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource StatusErrorBrush}"
                                       FontFamily="Consolas,monospace" />
                        </StackPanel>
                    </Border>

                    <!-- Blossom Server -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Blossom media server" FontSize="14" />
                        <TextBlock Text="Server for uploading encrypted voice messages and media"
                                   Classes="muted" FontSize="12" />

                        <!-- Display mode: label showing current domain -->
                        <StackPanel IsVisible="{Binding !IsEditingBlossom}" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="https://" FontFamily="Consolas,monospace" FontSize="13"
                                       VerticalAlignment="Center" Opacity="0.5" />
                            <TextBlock Text="{Binding BlossomServerDomain}" FontFamily="Consolas,monospace"
                                       FontSize="13" VerticalAlignment="Center" Cursor="Hand" />
                            <Button Classes="icon" Command="{Binding EditBlossomCommand}"
                                    ToolTip.Tip="Edit" Padding="4">
                                <PathIcon Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1.003 1.003 0 0 0 0-1.42l-2.34-2.34a1.003 1.003 0 0 0-1.42 0l-1.83 1.83 3.75 3.75 1.84-1.82z"
                                          Width="14" Height="14" />
                            </Button>
                        </StackPanel>

                        <!-- Edit mode: input + save/cancel -->
                        <StackPanel IsVisible="{Binding IsEditingBlossom}" Spacing="4">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="https://" FontFamily="Consolas,monospace"
                                           FontSize="13" VerticalAlignment="Center" Opacity="0.5" Margin="0,0,2,0" />
                                <TextBox Grid.Column="1" Text="{Binding BlossomServerDomain}"
                                         PlaceholderText="blossom.example.com"
                                         FontFamily="Consolas,monospace" FontSize="13">
                                    <TextBox.KeyBindings>
                                        <KeyBinding Gesture="Enter" Command="{Binding SaveBlossomCommand}" />
                                    </TextBox.KeyBindings>
                                </TextBox>
                                <Button Grid.Column="2" Classes="primary" Content="Save"
                                        Command="{Binding SaveBlossomCommand}" Margin="8,0,0,0" />
                                <Button Grid.Column="3" Classes="secondary" Content="Cancel"
                                        Command="{Binding CancelEditBlossomCommand}" Margin="4,0,0,0" />
                            </Grid>
                        </StackPanel>

                        <!-- Validation status -->
                        <TextBlock Text="{Binding BlossomStatus}"
                                   IsVisible="{Binding BlossomStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Foreground="{DynamicResource StatusOnlineBrush}"
                                   FontSize="12" FontWeight="SemiBold">
                            <TextBlock.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="BlossomStatus" Converter="{x:Static StringConverters.IsNotNullOrEmpty}" />
                                    <Binding Path="!BlossomStatusIsError" />
                                </MultiBinding>
                            </TextBlock.IsVisible>
                        </TextBlock>
                        <TextBlock Text="{Binding BlossomStatus}"
                                   IsVisible="{Binding BlossomStatusIsError}"
                                   Foreground="{DynamicResource StatusErrorBrush}"
                                   FontSize="12" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Notifications Section -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Notifications" FontWeight="SemiBold" FontSize="16" />

                    <!-- Desktop: notifications are always active -->
                    <TextBlock Text="Desktop notifications are always active when the app is not in focus. No configuration needed."
                               Classes="muted" FontSize="12"
                               IsVisible="{Binding IsDesktop}" />

                    <!-- Mobile: opt-in background/push modes -->
                    <StackPanel Spacing="8" IsVisible="{Binding IsMobile}">
                        <TextBlock Text="Choose how you want to receive notifications. Both options are off by default."
                                   Classes="muted" FontSize="12" />

                        <!-- Mode selection -->
                        <StackPanel Spacing="8">
                            <RadioButton Content="Background service (keep relay connections alive)"
                                         IsChecked="{Binding NotificationModeBackground}" />
                            <TextBlock Text="The app keeps relay connections open in the background. Uses more battery but works without a notification server. Requires notification permission on Android 13+."
                                       Classes="muted" FontSize="12"
                                       IsVisible="{Binding NotificationModeBackground}" />
                            <RadioButton Content="UnifiedPush (via ntfy)"
                                         IsChecked="{Binding NotificationModePush}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Push mode settings (mobile only) -->
                    <StackPanel Spacing="12" IsVisible="{Binding NotificationModePush}">
                        <TextBlock Text="Register with a notification server to receive push notifications. Lower battery usage."
                                   Classes="muted" FontSize="12" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Server npub" Classes="muted" FontSize="12" />
                            <TextBox Text="{Binding NotificationServerNpub}"
                                     FontFamily="Consolas,monospace" FontSize="13"
                                     PlaceholderText="npub1..." />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Server relay" Classes="muted" FontSize="12" />
                            <TextBox Text="{Binding NotificationServerRelay}"
                                     FontFamily="Consolas,monospace" FontSize="13"
                                     PlaceholderText="wss://relay.example.com" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Push URL" Classes="muted" FontSize="12" />
                            <TextBox Text="{Binding NotificationPushUrl}"
                                     FontFamily="Consolas,monospace" FontSize="13"
                                     PlaceholderText="https://ntfy.sh/your-topic" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="secondary" Content="Generate topic"
                                    Command="{Binding GeneratePushTopicCommand}" />
                            <Button Classes="secondary" Content="Open in ntfy"
                                    Command="{Binding SubscribeInNtfyCommand}" />
                        </StackPanel>

                        <Button Classes="primary" Content="Register"
                                Command="{Binding RegisterNotificationsCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center" />

                        <!-- Verification code (visible after registration) -->
                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding NotificationAwaitingVerification}">
                            <TextBox Grid.Column="0" Text="{Binding NotificationVerifyCode}"
                                     PlaceholderText="6-digit code"
                                     FontFamily="Consolas,monospace" FontSize="16" />
                            <Button Grid.Column="1" Classes="secondary" Content="Verify"
                                    Command="{Binding VerifyNotificationsCommand}"
                                    Margin="8,0,0,0" />
                        </Grid>

                        <TextBlock Text="{Binding NotificationRegistrationStatus}"
                                   IsVisible="{Binding NotificationRegistrationStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Classes="muted" FontSize="13" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Developer Section -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Developer" FontWeight="SemiBold" FontSize="16" />

                    <!-- View Logs -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Application Logs" Classes="secondary" FontSize="13" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="secondary" Content="View Logs"
                                    Command="{Binding ViewLogsCommand}" />
                            <Button Classes="secondary" Content="Open Log Folder"
                                    Command="{Binding OpenLogFolderCommand}" />
                            <Button Classes="secondary" Content="Export Logs"
                                    Command="{Binding ExportLogsCommand}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- About Section -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="About Scramble" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Text="Scramble is an open-source chat application built with Nostr and the Marmot Protocol (MLS) for end-to-end encrypted messaging."
                               Classes="secondary" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="Version 0.1.0" Classes="muted" />
                        <TextBlock Text="Built with Avalonia" Classes="muted" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Logout -->
            <Button Content="Log Out" HorizontalAlignment="Stretch" Height="44"
                    Background="{DynamicResource DangerButtonBrush}" Foreground="White" FontWeight="SemiBold"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Command="{Binding LogoutCommand}" />
        </StackPanel>
    </ScrollViewer>

        <!-- Log Viewer Dialog Overlay -->
    <Border Grid.RowSpan="2" IsVisible="{Binding ShowLogViewer}"
            Background="#E0000000"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border Classes="card"
                Background="{DynamicResource BackgroundCardBrush}"
                CornerRadius="12"
                Padding="20"
                Margin="24"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,16">
                    <TextBlock Grid.Column="0" Text="Application Logs"
                               FontSize="20" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Classes="secondary" Content="Refresh"
                            Command="{Binding RefreshLogsCommand}"
                            Margin="0,0,8,0" />
                    <Button Grid.Column="2" Classes="icon"
                            Command="{Binding CloseLogViewerCommand}">
                        <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                  Width="20" Height="20" />
                    </Button>
                </Grid>

                <!-- Log Content -->
                <Border Grid.Row="1" Background="{DynamicResource SurfaceSecondaryBrush}"
                        CornerRadius="8" Padding="12">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding LogContent}"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   TextWrapping="NoWrap" />
                    </ScrollViewer>
                </Border>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Spacing="8" Margin="0,16,0,0">
                    <Button Classes="secondary" Content="Export Logs"
                            Command="{Binding ExportLogsCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" />
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Button Grid.Column="0" Classes="secondary" Content="Open Log Folder"
                                Command="{Binding OpenLogFolderCommand}" />
                        <Button Grid.Column="2" Classes="primary" Content="Close"
                                Command="{Binding CloseLogViewerCommand}" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
    </Grid>
</UserControl>

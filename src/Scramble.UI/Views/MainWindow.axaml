<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Scramble.Presentation.ViewModels"
        xmlns:views="using:Scramble.UI.Views"
        xmlns:asyncImageLoader="using:AsyncImageLoader"
        xmlns:converters="using:Scramble.UI.Converters"
        xmlns:config="using:Scramble.Core.Configuration"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Scramble.UI.Views.MainWindow"
        x:DataType="vm:ShellViewModel"
        Title="Scramble"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        ExtendClientAreaTitleBarHeightHint="38"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

    <Window.Resources>
        <converters:PngBytesToBitmapConverter x:Key="PngBytesToBitmapConverter" />
        <converters:FilePathToBitmapConverter x:Key="FilePathToBitmap" />
    </Window.Resources>

    <!-- Design-time DataContext disabled (ShellViewModel requires runtime services) -->

    <Border CornerRadius="12" ClipToBounds="True"
            Background="{DynamicResource BackgroundDarkBrush}">
    <Grid RowDefinitions="38,*">
        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource BackgroundLightBrush}"
                CornerRadius="12,12,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Drag region -->
                <Panel Grid.Column="0" Background="Transparent"
                       IsHitTestVisible="True"
                       PointerPressed="TitleBar_PointerPressed">
                    <TextBlock Text="Scramble" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="16,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </Panel>
                <!-- Window controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0"
                            VerticalAlignment="Stretch" Margin="0,0,4,0">
                    <Button Classes="icon" Click="MinimizeButton_Click" ToolTip.Tip="Minimize"
                            Width="36" Height="30" VerticalAlignment="Center" Padding="0">
                        <PathIcon Data="M20 14H4v-2h16" Width="14" Height="14" />
                    </Button>
                    <Button Classes="icon" Click="MaximizeButton_Click" ToolTip.Tip="Maximize"
                            Width="36" Height="30" VerticalAlignment="Center" Padding="0">
                        <PathIcon Data="M4 4h16v16H4V4zm2 2v12h12V6H6z" Width="14" Height="14" />
                    </Button>
                    <Button Classes="icon" Click="CloseButton_Click" ToolTip.Tip="Close"
                            Width="36" Height="30" VerticalAlignment="Center" Padding="0">
                        <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                  Width="14" Height="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

    <Grid Grid.Row="1">
        <!-- Main Chat View (shown when logged in) -->
        <Grid x:Name="MainGrid" IsVisible="False" ColumnDefinitions="350,*"
              DataContext="{Binding MainViewModel}" x:DataType="vm:MainViewModel">

            <!-- Left Sidebar -->
            <Border Grid.Column="0" Classes="sidebar">
                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="16,12" Background="{DynamicResource BackgroundLightBrush}">
                        <StackPanel Spacing="10">
                            <!-- Top row: avatar + name + action buttons -->
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                    <!-- User Avatar (clickable - opens account switcher) -->
                                    <Button x:Name="AvatarButton" Classes="icon"
                                            Click="AvatarButton_Click"
                                            ToolTip.Tip="Switch Account"
                                            Padding="0" CornerRadius="20">
                                        <Panel Width="40" Height="40">
                                            <!-- Fallback avatar icon (no picture) -->
                                            <Border Width="40" Height="40" CornerRadius="20"
                                                    Background="{DynamicResource NostrPurpleBrush}"
                                                    IsVisible="{Binding MyPictureUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}">
                                                <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"
                                                          Width="22" Height="22" Foreground="White" />
                                            </Border>
                                            <!-- Profile picture -->
                                            <Border Width="40" Height="40" CornerRadius="20" ClipToBounds="True"
                                                    IsVisible="{Binding MyPictureUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <Image asyncImageLoader:ImageLoader.Source="{Binding MyPictureUrl}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                        </Panel>
                                    </Button>
                                    <!-- Name or loading indicator -->
                                    <StackPanel VerticalAlignment="Center" MaxWidth="180">
                                        <TextBlock Text="{Binding HeaderDisplayName}" FontSize="18" FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip.Tip="{Binding CurrentUser.Npub}"
                                                   IsVisible="{Binding !IsHeaderLoading}" />
                                        <TextBlock Text="Loading..." FontSize="13" Classes="muted"
                                                   IsVisible="{Binding IsHeaderLoading}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                    <!-- Settings -->
                                    <Button Classes="icon" Command="{Binding ShowSettingsCommand}" ToolTip.Tip="Settings">
                                        <PathIcon Data="M12 15.5A3.5 3.5 0 0 1 8.5 12A3.5 3.5 0 0 1 12 8.5a3.5 3.5 0 0 1 3.5 3.5a3.5 3.5 0 0 1-3.5 3.5m7.43-2.53c.04-.32.07-.64.07-.97c0-.33-.03-.66-.07-1l2.11-1.63c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.31-.61-.22l-2.49 1c-.52-.39-1.06-.73-1.69-.98l-.37-2.65A.506.506 0 0 0 14 2h-4c-.25 0-.46.18-.5.42l-.37 2.65c-.63.25-1.17.59-1.69.98l-2.49-1c-.22-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64L4.57 11c-.04.34-.07.67-.07 1c0 .33.03.65.07.97l-2.11 1.66c-.19.15-.25.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1.01c.52.4 1.06.74 1.69.99l.37 2.65c.04.24.25.42.5.42h4c.25 0 .46-.18.5-.42l.37-2.65c.63-.26 1.17-.59 1.69-.99l2.49 1.01c.22.08.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.66Z"
                                                  Width="20" Height="20" />
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- No internet banner -->
                            <Border IsVisible="{Binding ShowNoInternet}"
                                    Background="{DynamicResource StatusErrorBrush}"
                                    CornerRadius="4" Padding="8,4" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="M24 24l-4.2-4.2M21.49 21.49L2.51 2.51M1 1l4.05 4.05M11 3c5.52 0 10 4.48 10 10c0 2.16-.69 4.16-1.86 5.79L11 10.71M3.14 7.14C2.4 8.57 2 10.24 2 12c0 2.76 1.12 5.26 2.93 7.07L12 12"
                                              Width="14" Height="14" Foreground="White" />
                                    <TextBlock Text="No internet connection"
                                               Foreground="White" FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Forward-secrecy disclosure banner (multi-device) -->
                            <Border IsVisible="{Binding ShowForwardSecrecyBanner}"
                                    Background="{DynamicResource StatusWarningBrush}"
                                    CornerRadius="4" Padding="8,6" Margin="0,4,0,0">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="New device linked"
                                                   Foreground="White" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Messages sent before linking are not available on this device due to forward secrecy."
                                                   Foreground="White" FontSize="11" TextWrapping="Wrap" Opacity="0.9" />
                                        <TextBlock Text="{Binding SkippedNonAdminGroupsText, StringFormat='Ask admins to add your device to: {0}'}"
                                                   IsVisible="{Binding SkippedNonAdminGroupsText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                   Foreground="White" FontSize="11" TextWrapping="Wrap" Opacity="0.85" FontStyle="Italic" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Classes="secondary"
                                            Command="{Binding DismissForwardSecrecyBannerCommand}"
                                            Content="Dismiss" FontSize="11" Padding="8,2"
                                            VerticalAlignment="Top" Margin="6,0,0,0" />
                                </Grid>
                            </Border>

                            <!-- Relay summary row (always visible) -->
                            <Button Classes="secondary"
                                    Command="{Binding ToggleRelayListCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Padding="8,4">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <!-- Overall status dot -->
                                    <Panel Grid.Column="0" Width="7" Height="7"
                                           VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{DynamicResource StatusOnlineBrush}"
                                                 IsVisible="{Binding IsConnected}" />
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{DynamicResource StatusErrorBrush}"
                                                 IsVisible="{Binding !IsConnected}" />
                                    </Panel>
                                    <TextBlock Grid.Column="1" Text="{Binding RelayCountText}"
                                               FontSize="12" VerticalAlignment="Center" />
                                    <!-- Expand/collapse chevron (right-aligned) -->
                                    <Panel Grid.Column="2" VerticalAlignment="Center">
                                        <PathIcon Width="12" Height="12"
                                                  Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6l-6-6l1.41-1.41z"
                                                  IsVisible="{Binding !IsRelayListExpanded}" />
                                        <PathIcon Width="12" Height="12"
                                                  Data="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6l-6 6l1.41 1.41z"
                                                  IsVisible="{Binding IsRelayListExpanded}" />
                                    </Panel>
                                </Grid>
                            </Button>

                            <!-- Expanded relay list (toggled) -->
                            <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto"
                                          IsVisible="{Binding IsRelayListExpanded}">
                                <ItemsControl ItemsSource="{Binding RelayStatuses}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RelayStatusViewModel">
                                            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
                                                <!-- Green/Red dot -->
                                                <Panel Grid.Column="0" Width="7" Height="7"
                                                       VerticalAlignment="Center" Margin="4,0,6,0">
                                                    <Ellipse Width="7" Height="7"
                                                             Fill="{DynamicResource StatusOnlineBrush}"
                                                             IsVisible="{Binding IsConnected}" />
                                                    <Ellipse Width="7" Height="7"
                                                             Fill="{DynamicResource StatusErrorBrush}"
                                                             IsVisible="{Binding !IsConnected}" />
                                                </Panel>
                                                <!-- Relay name -->
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                           Classes="muted" FontSize="11"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                                <!-- Per-relay reconnect button -->
                                                <Button Grid.Column="2" Classes="secondary"
                                                        Padding="4,1" FontSize="9" Margin="4,0,0,0"
                                                        IsVisible="{Binding !IsConnected}"
                                                        IsEnabled="{Binding !IsReconnecting}"
                                                        Command="{Binding $parent[ItemsControl].DataContext.ReconnectRelayCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Reconnect this relay">
                                                    <Panel>
                                                        <PathIcon Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                                                  Width="10" Height="10"
                                                                  IsVisible="{Binding !IsReconnecting}" />
                                                        <TextBlock Text="..." FontSize="9"
                                                                   IsVisible="{Binding IsReconnecting}" />
                                                    </Panel>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <!-- Reconnect All (inside expanded panel) -->
                            <Button Content="Reconnect All"
                                    Command="{Binding ReconnectCommand}"
                                    IsVisible="{Binding IsRelayListExpanded}"
                                    Classes="secondary"
                                    Padding="8,3" Margin="0,4,0,0"
                                    FontSize="10"
                                    HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <!-- Chat List -->
                    <views:ChatListView Grid.Row="1" DataContext="{Binding ChatListViewModel}" />

                    <!-- Footer Buttons -->
                    <Border Grid.Row="2" Padding="12" Background="{DynamicResource BackgroundLightBrush}">
                        <Grid ColumnDefinitions="*,8,*">
                            <!-- New Chat Button -->
                            <Button Grid.Column="0" Classes="secondary" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Command="{Binding ChatListViewModel.NewChatCommand}"
                                    Padding="8,6" ToolTip.Tip="New Chat">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" Width="16" Height="16" />
                                    <TextBlock Text="Chat" FontSize="13" />
                                </StackPanel>
                            </Button>
                            <!-- Link Device Button -->
                            <Button Grid.Column="2" Classes="secondary" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Command="{Binding ChatListViewModel.AddBotCommand}"
                                    Padding="8,6" ToolTip.Tip="Link Device">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <!-- Devices icon (Material Symbols Outlined) -->
                                    <PathIcon Data="M80-160v-120h80v-440q0-33 23.5-56.5T240-800h600v80H240v440h240v120H80Zm520 0q-17 0-28.5-11.5T560-200v-400q0-17 11.5-28.5T600-640h240q17 0 28.5 11.5T880-600v400q0 17-11.5 28.5T840-160H600Zm40-120h160v-280H640v280Zm0 0h160-160Z"
                                              Width="16" Height="16" />
                                    <TextBlock Text="Device" FontSize="13" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1">
                <!-- Settings View (when CurrentView is SettingsViewModel) -->
                <views:SettingsView DataContext="{Binding SettingsViewModel}"
                                    IsVisible="{Binding #MainGrid.DataContext.CurrentView, Converter={x:Static ObjectConverters.IsNotNull}}" />

                <!-- Chat View (when no special view selected) -->
                <views:ChatView DataContext="{Binding ChatViewModel}"
                                IsVisible="{Binding #MainGrid.DataContext.CurrentView, Converter={x:Static ObjectConverters.IsNull}}" />

                <!-- Empty State (when no chat selected and not in settings) -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="16">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="!ChatViewModel.HasChat" />
                            <Binding Path="CurrentView" Converter="{x:Static ObjectConverters.IsNull}" />
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <Border Width="120" Height="120" CornerRadius="60"
                            Background="{DynamicResource SurfaceSecondaryBrush}">
                        <PathIcon Data="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"
                                  Width="60" Height="60" Foreground="{DynamicResource TextMutedBrush}" />
                    </Border>
                    <TextBlock Text="Select a chat to start messaging"
                               Classes="secondary" FontSize="16" HorizontalAlignment="Center" />
                    <TextBlock Text="Or create a new chat using the button below"
                               Classes="muted" FontSize="14" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Login View (shown when not logged in) -->
        <views:LoginView x:Name="LoginViewControl" DataContext="{Binding LoginViewModel}" />

        <!-- Account Switcher Overlay (bound to ShellViewModel) -->
        <!-- Reuses the shared AccountSwitcherView UserControl; mobile shell renders the same control. -->
        <ContentControl IsVisible="{Binding ShowAccountSwitcher}">
            <views:AccountSwitcherView />
        </ContentControl>

        <!-- My Profile / Export npub Dialog (only when logged in and dialog open) -->
        <!-- Reuses the shared MyProfileDialogView UserControl; mobile shell renders the same control. -->
        <ContentControl DataContext="{Binding MainViewModel}"
                        x:DataType="vm:MainViewModel"
                        IsVisible="{Binding ShowMyProfileDialog, FallbackValue=False}">
            <views:MyProfileDialogView />
        </ContentControl>
        <!-- New Chat Dialog Overlay (window-level, over both panels) -->
        <!-- Reuses the shared NewChatDialogView UserControl; mobile shell renders the same control. -->
        <ContentControl DataContext="{Binding MainViewModel.ChatListViewModel}"
                        x:DataType="vm:ChatListViewModel"
                        IsVisible="{Binding ShowNewChatDialog, FallbackValue=False}">
            <views:NewChatDialogView />
        </ContentControl>

        <!-- Add Bot Dialog Overlay (window-level, over both panels) -->
        <Border DataContext="{Binding MainViewModel.ChatListViewModel}" x:DataType="vm:ChatListViewModel"
                IsVisible="{Binding ShowAddBotDialog, FallbackValue=False}"
                Background="#80000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Classes="card"
                    Background="{DynamicResource BackgroundCardBrush}"
                    CornerRadius="16"
                    Padding="24"
                    Margin="20"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    MinWidth="400" MaxWidth="500">
                <Panel>
                    <!-- Form content (hidden during connecting) -->
                    <StackPanel Spacing="16"
                                IsVisible="{Binding !CreateBotChatCommand.IsExecuting^}">
                        <!-- Header -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Link Device"
                                       FontSize="22" FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1" Classes="icon"
                                    Command="{Binding CancelAddBotCommand}"
                                    ToolTip.Tip="Close">
                                <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                          Width="20" Height="20" />
                            </Button>
                        </Grid>

                        <!-- Device Public Key Input -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Device Public Key" Classes="secondary" FontSize="13" />
                            <TextBox Text="{Binding BotNpub}"
                                     PlaceholderText="npub1..."
                                     AcceptsReturn="False" />
                            <TextBlock Text="Enter the npub of a bot or IoT device. Messages use NIP-17 encrypted DMs."
                                       Classes="muted" FontSize="11" TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- Relay Selection -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Relay" Classes="secondary" FontSize="13" />

                            <!-- Radio buttons -->
                            <RadioButton Content="Find user relay (NIP-65)"
                                         IsChecked="{Binding BotRelayModeNip65}"
                                         GroupName="BotRelay" />
                            <RadioButton Content="Select from connected relays"
                                         IsChecked="{Binding BotRelayModeList}"
                                         GroupName="BotRelay" />
                            <RadioButton Content="Add relay manually"
                                         IsChecked="{Binding BotRelayModeManual}"
                                         GroupName="BotRelay" />

                            <!-- NIP-65 panel -->
                            <StackPanel Spacing="4" IsVisible="{Binding BotRelayModeNip65}">
                                <Button Classes="secondary" Content="Look up relays"
                                        Command="{Binding LookupBotNip65Command}"
                                        Padding="12,4" FontSize="12"
                                        HorizontalAlignment="Left" />
                                <ProgressBar IsIndeterminate="True" Height="2"
                                             IsVisible="{Binding IsFetchingNip65}"
                                             Foreground="{DynamicResource NostrPurpleBrush}" />
                                <TextBlock Text="{Binding Nip65Status}"
                                           FontSize="12" TextWrapping="Wrap"
                                           IsVisible="{Binding Nip65Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                <ItemsControl ItemsSource="{Binding BotNip65Relays}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Url}" IsChecked="{Binding IsChecked}"
                                                      FontSize="12" Margin="0,1" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Select from list panel -->
                            <StackPanel Spacing="4" IsVisible="{Binding BotRelayModeList}">
                                <ItemsControl ItemsSource="{Binding BotAvailableRelays}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Url}" IsChecked="{Binding IsChecked}"
                                                      FontSize="12" Margin="0,1" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No relays connected."
                                           Classes="muted" FontSize="12"
                                           IsVisible="{Binding !BotAvailableRelays.Count}" />
                            </StackPanel>

                            <!-- Manual relay panel -->
                            <StackPanel Spacing="4" IsVisible="{Binding BotRelayModeManual}">
                                <TextBox Text="{Binding BotManualRelay}"
                                         PlaceholderText="wss://relay.example.com"
                                         AcceptsReturn="False" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Error Message -->
                        <TextBlock Text="{Binding AddBotError}"
                                   Foreground="{DynamicResource StatusErrorBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding AddBotError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <!-- Buttons -->
                        <Grid ColumnDefinitions="*,12,*" Margin="0,8,0,0">
                            <Button Grid.Column="0"
                                    Classes="secondary"
                                    Content="Cancel"
                                    Command="{Binding CancelAddBotCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" />
                            <Button Grid.Column="2"
                                    Classes="primary"
                                    Content="Link"
                                    Command="{Binding CreateBotChatCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <!-- Progress overlay (shown while connecting) -->
                    <StackPanel IsVisible="{Binding CreateBotChatCommand.IsExecuting^}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="16"
                                Margin="40">
                        <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                     Foreground="{DynamicResource NostrPurpleBrush}" />
                        <TextBlock Text="Linking device..."
                                   FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="This may take a moment"
                                   Classes="muted" FontSize="12"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Panel>
            </Border>
        </Border>

    </Grid>
    </Grid>
    </Border>
</Window>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OpenChat.Presentation.ViewModels"
             xmlns:conv="using:OpenChat.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="80"
             x:Class="OpenChat.UI.Controls.MessageBubble"
             x:DataType="vm:MessageViewModel">

    <UserControl.Resources>
        <conv:PngBytesToBitmapConverter x:Key="BytesToBitmap" />
    </UserControl.Resources>

    <Grid>
        <!-- Received Message (left aligned) -->
        <Border HorizontalAlignment="Left" MaxWidth="480"
                IsVisible="{Binding !IsFromCurrentUser}"
                Background="{StaticResource BubbleReceivedBrush}"
                CornerRadius="16,16,16,4" Padding="12,8">
            <StackPanel Spacing="4">
                <!-- Sender Name (for groups) -->
                <TextBlock Text="{Binding SenderName}"
                           Foreground="{StaticResource NostrPurpleLightBrush}"
                           FontSize="12" FontWeight="SemiBold"
                           IsVisible="{Binding IsFirstInGroup}" />

                <!-- Image Media Widget (for image messages) -->
                <Border IsVisible="{Binding IsImage}"
                        CornerRadius="8" Margin="0,2" ClipToBounds="True">
                    <StackPanel Spacing="4">

                        <!-- State 1: MIP-04 Disabled -->
                        <Border IsVisible="{Binding ShowMediaDisabled}"
                                Background="{StaticResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Media loading disabled"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="13" FontStyle="Italic" />
                                <TextBlock Text="Enable in Settings > Privacy"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11" />
                            </StackPanel>
                        </Border>

                        <!-- State 2: Tap to Load -->
                        <Border IsVisible="{Binding ShowTapToLoad}"
                                Background="{StaticResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="Auto,*">
                                    <PathIcon Grid.Column="0"
                                              Data="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"
                                              Width="18" Height="18" Margin="0,0,8,0"
                                              Foreground="{StaticResource TextMutedBrush}"
                                              VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ImageDisplayText}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="13" FontStyle="Italic"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <Button Classes="secondary" Content="Tap to load"
                                        Command="{Binding LoadMediaCommand}"
                                        HorizontalAlignment="Left"
                                        Padding="12,4" FontSize="12" />
                                <TextBlock Text="(your IP will be visible to the host)"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="10" />
                                <!-- Unknown server warning -->
                                <StackPanel Orientation="Horizontal" Spacing="4"
                                            IsVisible="{Binding IsUnknownServer}">
                                    <PathIcon Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"
                                              Width="14" Height="14"
                                              Foreground="{StaticResource StatusWarningBrush}" />
                                    <TextBlock Text="{Binding ServerHostname, StringFormat='Unknown server: {0}'}"
                                               Foreground="{StaticResource StatusWarningBrush}"
                                               FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- State 3: Loading -->
                        <Border IsVisible="{Binding IsLoadingMedia}"
                                Background="{StaticResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Loading..." Classes="muted" FontSize="13" />
                                <TextBlock Text="{Binding MediaSizeDisplay}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- State 4: Loaded (show image) -->
                        <Image IsVisible="{Binding IsMediaLoaded}"
                               Source="{Binding DecryptedMediaBytes, Converter={StaticResource BytesToBitmap}}"
                               MaxWidth="400" MaxHeight="400"
                               Stretch="Uniform"
                               HorizontalAlignment="Left" />

                        <!-- State 5: Error -->
                        <Border IsVisible="{Binding MediaError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Background="{StaticResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <TextBlock Text="{Binding MediaError}"
                                       Foreground="{StaticResource StatusErrorBrush}"
                                       FontSize="12" TextWrapping="Wrap" />
                        </Border>

                    </StackPanel>
                </Border>

                <!-- Audio Player (for voice messages) -->
                <StackPanel IsVisible="{Binding IsAudio}" Spacing="4">
                    <!-- Load button (before download) -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding ShowTapToLoad}">
                        <Button Command="{Binding LoadMediaCommand}"
                                Width="36" Height="36" CornerRadius="18"
                                Padding="0" Classes="primary">
                            <PathIcon Data="M8 5v14l11-7z" Width="16" Height="16" Foreground="White" />
                        </Button>
                        <TextBlock Text="{Binding ImageDisplayText}"
                                   VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>

                    <!-- Mini player (after download/decode) -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                Margin="4,4,0,0"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsMediaLoaded}">
                        <!-- Play/Pause button -->
                        <Button Command="{Binding ToggleAudioCommand}"
                                Width="32" Height="32" CornerRadius="16"
                                Padding="0" Classes="primary">
                            <Panel>
                                <!-- Play icon -->
                                <PathIcon Data="M8 5v14l11-7z" Width="14" Height="14"
                                          Foreground="White"
                                          IsVisible="{Binding !IsPlayingAudio}" />
                                <!-- Pause icon -->
                                <PathIcon Data="M6 19h4V5H6v14zm8-14v14h4V5h-4z" Width="14" Height="14"
                                          Foreground="White"
                                          IsVisible="{Binding IsPlayingAudio}" />
                            </Panel>
                        </Button>

                        <!-- Progress bar -->
                        <Slider Minimum="0" Maximum="1" Value="{Binding AudioProgress}"
                                Width="120" VerticalAlignment="Center"
                                IsHitTestVisible="False" />

                        <!-- Duration -->
                        <TextBlock Text="{Binding AudioDurationText}"
                                   VerticalAlignment="Center" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>

                    <!-- Disabled state -->
                    <TextBlock Text="{Binding ImageDisplayText}"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"
                               IsVisible="{Binding ShowMediaDisabled}" />

                    <!-- Error state -->
                    <TextBlock Text="{Binding MediaError}"
                               FontSize="13"
                               Foreground="{StaticResource StatusErrorBrush}"
                               IsVisible="{Binding MediaError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>

                <!-- Text Content (for non-image/non-audio messages) -->
                <TextBlock Text="{Binding Content}"
                           Foreground="{StaticResource BubbleReceivedText}"
                           TextWrapping="Wrap" FontSize="14"
                           IsVisible="{Binding IsTextMessage}" />

                <!-- Timestamp -->
                <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" HorizontalAlignment="Right" />
            </StackPanel>
        </Border>

        <!-- Sent Message (right aligned) -->
        <Border HorizontalAlignment="Right" MaxWidth="480"
                IsVisible="{Binding IsFromCurrentUser}"
                Background="{StaticResource BubbleSentBrush}"
                CornerRadius="16,16,4,16" Padding="12,8">
            <StackPanel Spacing="4">

                <!-- Image Media Widget (for image messages) -->
                <Border IsVisible="{Binding IsImage}"
                        CornerRadius="8" Margin="0,2" ClipToBounds="True">
                    <StackPanel Spacing="4">

                        <!-- State 1: MIP-04 Disabled -->
                        <Border IsVisible="{Binding ShowMediaDisabled}"
                                Background="{StaticResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Media loading disabled"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="13" FontStyle="Italic" />
                                <TextBlock Text="Enable in Settings > Privacy"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11" />
                            </StackPanel>
                        </Border>

                        <!-- State 2: Tap to Load -->
                        <Border IsVisible="{Binding ShowTapToLoad}"
                                Background="{StaticResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="Auto,*">
                                    <PathIcon Grid.Column="0"
                                              Data="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"
                                              Width="18" Height="18" Margin="0,0,8,0"
                                              Foreground="{StaticResource TextMutedBrush}"
                                              VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ImageDisplayText}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="13" FontStyle="Italic"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <Button Classes="secondary" Content="Tap to load"
                                        Command="{Binding LoadMediaCommand}"
                                        HorizontalAlignment="Left"
                                        Padding="12,4" FontSize="12" />
                                <TextBlock Text="(your IP will be visible to the host)"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="10" />
                                <!-- Unknown server warning -->
                                <StackPanel Orientation="Horizontal" Spacing="4"
                                            IsVisible="{Binding IsUnknownServer}">
                                    <PathIcon Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"
                                              Width="14" Height="14"
                                              Foreground="{StaticResource StatusWarningBrush}" />
                                    <TextBlock Text="{Binding ServerHostname, StringFormat='Unknown server: {0}'}"
                                               Foreground="{StaticResource StatusWarningBrush}"
                                               FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- State 3: Loading -->
                        <Border IsVisible="{Binding IsLoadingMedia}"
                                Background="{StaticResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Loading..." Classes="muted" FontSize="13" />
                                <TextBlock Text="{Binding MediaSizeDisplay}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- State 4: Loaded (show image) -->
                        <Image IsVisible="{Binding IsMediaLoaded}"
                               Source="{Binding DecryptedMediaBytes, Converter={StaticResource BytesToBitmap}}"
                               MaxWidth="400" MaxHeight="400"
                               Stretch="Uniform"
                               HorizontalAlignment="Right" />

                        <!-- State 5: Error -->
                        <Border IsVisible="{Binding MediaError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Background="{StaticResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <TextBlock Text="{Binding MediaError}"
                                       Foreground="{StaticResource StatusErrorBrush}"
                                       FontSize="12" TextWrapping="Wrap" />
                        </Border>

                    </StackPanel>
                </Border>

                <!-- Audio Player (for voice messages) -->
                <StackPanel IsVisible="{Binding IsAudio}" Spacing="4">
                    <!-- Load button (before download) -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding ShowTapToLoad}">
                        <Button Command="{Binding LoadMediaCommand}"
                                Width="36" Height="36" CornerRadius="18"
                                Padding="0" Classes="primary">
                            <PathIcon Data="M8 5v14l11-7z" Width="16" Height="16" Foreground="White" />
                        </Button>
                        <TextBlock Text="{Binding ImageDisplayText}"
                                   VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>

                    <!-- Mini player (after download/decode) -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                Margin="4,4,0,0"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsMediaLoaded}">
                        <Button Command="{Binding ToggleAudioCommand}"
                                Width="32" Height="32" CornerRadius="16"
                                Padding="0" Classes="primary">
                            <Panel>
                                <PathIcon Data="M8 5v14l11-7z" Width="14" Height="14"
                                          Foreground="White"
                                          IsVisible="{Binding !IsPlayingAudio}" />
                                <PathIcon Data="M6 19h4V5H6v14zm8-14v14h4V5h-4z" Width="14" Height="14"
                                          Foreground="White"
                                          IsVisible="{Binding IsPlayingAudio}" />
                            </Panel>
                        </Button>
                        <Slider Minimum="0" Maximum="1" Value="{Binding AudioProgress}"
                                Width="120" VerticalAlignment="Center"
                                IsHitTestVisible="False" />
                        <TextBlock Text="{Binding AudioDurationText}"
                                   VerticalAlignment="Center" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>

                    <!-- Disabled / Error states -->
                    <TextBlock Text="{Binding ImageDisplayText}"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"
                               IsVisible="{Binding ShowMediaDisabled}" />
                    <TextBlock Text="{Binding MediaError}"
                               FontSize="13"
                               Foreground="{StaticResource StatusErrorBrush}"
                               IsVisible="{Binding MediaError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>

                <!-- Text Content (for non-image/non-audio messages) -->
                <TextBlock Text="{Binding Content}"
                           Foreground="{StaticResource BubbleSentText}"
                           TextWrapping="Wrap" FontSize="14"
                           IsVisible="{Binding IsTextMessage}" />

                <!-- Timestamp -->
                <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}"
                           Foreground="{StaticResource NostrPurpleAccent}"
                           FontSize="11" HorizontalAlignment="Right" Opacity="0.8" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

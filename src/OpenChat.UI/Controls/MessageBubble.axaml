<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OpenChat.Presentation.ViewModels"
             xmlns:conv="using:OpenChat.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="80"
             x:Class="OpenChat.UI.Controls.MessageBubble"
             x:DataType="vm:MessageViewModel">

    <UserControl.Resources>
        <conv:PngBytesToBitmapConverter x:Key="BytesToBitmap" />
    </UserControl.Resources>

    <Grid>
        <!-- Received Message (left aligned) -->
        <Border HorizontalAlignment="Left" MaxWidth="480"
                IsVisible="{Binding !IsFromCurrentUser}"
                Background="{DynamicResource BubbleReceivedBrush}"
                CornerRadius="16,16,16,4" Padding="12,8">
            <StackPanel Spacing="4">
                <!-- Sender Name (for groups) -->
                <TextBlock Text="{Binding SenderName}"
                           Foreground="{DynamicResource NostrPurpleLightBrush}"
                           FontSize="12" FontWeight="SemiBold"
                           IsVisible="{Binding IsFirstInGroup}" />

                <!-- Reply quote -->
                <Border IsVisible="{Binding HasReplyTo}"
                        BorderBrush="{DynamicResource NostrPurpleBrush}" BorderThickness="2,0,0,0"
                        Padding="8,4" Margin="0,2" Background="{DynamicResource SurfaceSecondaryBrush}"
                        CornerRadius="0,4,4,0">
                    <StackPanel Spacing="1">
                        <TextBlock Text="{Binding ReplyToSenderName}"
                                   Foreground="{DynamicResource NostrPurpleLightBrush}"
                                   FontSize="11" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ReplyToContent}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" TextTrimming="CharacterEllipsis" MaxLines="2" />
                    </StackPanel>
                </Border>

                <!-- Image Media Widget (for image messages) -->
                <Border IsVisible="{Binding IsImage}"
                        CornerRadius="8" Margin="0,2" ClipToBounds="True">
                    <StackPanel Spacing="4">

                        <!-- State 1: MIP-04 Disabled -->
                        <Border IsVisible="{Binding ShowMediaDisabled}"
                                Background="{DynamicResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Media loading disabled"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="13" FontStyle="Italic" />
                                <TextBlock Text="Enable in Settings > Privacy"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11" />
                            </StackPanel>
                        </Border>

                        <!-- State 2: Tap to Load -->
                        <Border IsVisible="{Binding ShowTapToLoad}"
                                Background="{DynamicResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="Auto,*">
                                    <PathIcon Grid.Column="0"
                                              Data="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"
                                              Width="18" Height="18" Margin="0,0,8,0"
                                              Foreground="{DynamicResource TextMutedBrush}"
                                              VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ImageDisplayText}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="13" FontStyle="Italic"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <Button Classes="secondary" Content="Tap to load"
                                        Command="{Binding LoadMediaCommand}"
                                        HorizontalAlignment="Left"
                                        Padding="12,4" FontSize="12" />
                                <TextBlock Text="(your IP will be visible to the host)"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="10" />
                                <!-- Unknown server warning -->
                                <StackPanel Orientation="Horizontal" Spacing="4"
                                            IsVisible="{Binding IsUnknownServer}">
                                    <PathIcon Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"
                                              Width="14" Height="14"
                                              Foreground="{DynamicResource StatusWarningBrush}" />
                                    <TextBlock Text="{Binding ServerHostname, StringFormat='Unknown server: {0}'}"
                                               Foreground="{DynamicResource StatusWarningBrush}"
                                               FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- State 3: Loading -->
                        <Border IsVisible="{Binding IsLoadingMedia}"
                                Background="{DynamicResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Loading..." Classes="muted" FontSize="13" />
                                <TextBlock Text="{Binding MediaSizeDisplay}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- State 4: Loaded (show image) -->
                        <Image IsVisible="{Binding IsMediaLoaded}"
                               Source="{Binding DecryptedMediaBytes, Converter={StaticResource BytesToBitmap}}"
                               MaxWidth="400" MaxHeight="400"
                               Stretch="Uniform"
                               HorizontalAlignment="Left" />

                        <!-- State 5: Error -->
                        <Border IsVisible="{Binding MediaError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Background="{DynamicResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <TextBlock Text="{Binding MediaError}"
                                       Foreground="{DynamicResource StatusErrorBrush}"
                                       FontSize="12" TextWrapping="Wrap" />
                        </Border>

                    </StackPanel>
                </Border>

                <!-- Audio Player (for voice messages) -->
                <StackPanel IsVisible="{Binding IsAudio}" Spacing="4">
                    <!-- Load button (before download) -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding ShowTapToLoad}">
                        <Button Command="{Binding LoadMediaCommand}"
                                Width="36" Height="36" CornerRadius="18"
                                Padding="0" Classes="primary">
                            <PathIcon Data="M8 5v14l11-7z" Width="16" Height="16" Foreground="White" />
                        </Button>
                        <TextBlock Text="{Binding ImageDisplayText}"
                                   VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>

                    <!-- Mini audio player (after download/decode) -->
                    <Border IsVisible="{Binding IsMediaLoaded}"
                            Background="{DynamicResource SurfaceTertiaryBrush}"
                            CornerRadius="20" Padding="4,4,12,4"
                            Margin="0,4,0,0"
                            MinWidth="260" MaxWidth="320">
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <!-- Play/Pause button -->
                            <Button Grid.Column="0"
                                    Command="{Binding ToggleAudioCommand}"
                                    Width="36" Height="36" CornerRadius="18"
                                    Padding="0" Classes="primary" Margin="0,0,8,0">
                                <Panel>
                                    <PathIcon Data="M8 5v14l11-7z" Width="14" Height="14"
                                              Foreground="White"
                                              IsVisible="{Binding !IsPlayingAudio}" />
                                    <PathIcon Data="M6 19h4V5H6v14zm8-14v14h4V5h-4z" Width="14" Height="14"
                                              Foreground="White"
                                              IsVisible="{Binding IsPlayingAudio}" />
                                </Panel>
                            </Button>

                            <!-- Seekable progress slider -->
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="1"
                                    Value="{Binding AudioProgress}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0"
                                    PointerPressed="AudioSlider_PointerPressed"
                                    PointerReleased="AudioSlider_PointerReleased" />

                            <!-- Elapsed / Duration -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding AudioTimeDisplay}"
                                       VerticalAlignment="Center"
                                       FontSize="11" FontFamily="Consolas,monospace"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       MinWidth="70" TextAlignment="Right" />
                        </Grid>
                    </Border>

                    <!-- Disabled state -->
                    <TextBlock Text="{Binding ImageDisplayText}"
                               FontSize="13"
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsVisible="{Binding ShowMediaDisabled}" />

                    <!-- Error state -->
                    <TextBlock Text="{Binding MediaError}"
                               FontSize="13"
                               Foreground="{DynamicResource StatusErrorBrush}"
                               IsVisible="{Binding MediaError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>

                <!-- File Attachment (for file messages) -->
                <Border IsVisible="{Binding IsFile}"
                        Background="{DynamicResource SurfaceSecondaryBrush}"
                        CornerRadius="8" Padding="12,8" Margin="0,2">
                    <StackPanel Spacing="4">
                        <!-- File icon + metadata (always visible) -->
                        <Grid ColumnDefinitions="Auto,*">
                            <PathIcon Grid.Column="0"
                                      Data="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zM6 20V4h7v5h5v11H6z"
                                      Width="20" Height="20" Margin="0,0,10,0"
                                      Foreground="{DynamicResource TextMutedBrush}"
                                      VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="1">
                                <TextBlock Text="{Binding ImageDisplayText}"
                                           FontSize="13" TextWrapping="Wrap"
                                           Foreground="{DynamicResource BubbleReceivedTextBrush}" />
                            </StackPanel>
                        </Grid>

                        <!-- Download button (MIP-04 enabled, not yet loaded) -->
                        <Button Classes="secondary" Content="Download"
                                Command="{Binding LoadMediaCommand}"
                                HorizontalAlignment="Left"
                                Padding="12,4" FontSize="12"
                                IsVisible="{Binding ShowTapToLoad}" />

                        <!-- MIP-04 disabled -->
                        <TextBlock Text="Media loading disabled — enable in Settings"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11" FontStyle="Italic"
                                   IsVisible="{Binding ShowMediaDisabled}" />

                        <!-- Loading -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding IsLoadingMedia}">
                            <TextBlock Text="Downloading..." Classes="muted" FontSize="12" />
                            <TextBlock Text="{Binding MediaSizeDisplay}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="12" />
                        </StackPanel>

                        <!-- Downloaded -->
                        <TextBlock Text="Downloaded"
                                   FontSize="12" Foreground="{DynamicResource StatusOnlineBrush}"
                                   IsVisible="{Binding IsMediaLoaded}" />

                        <!-- Error -->
                        <TextBlock Text="{Binding MediaError}"
                                   Foreground="{DynamicResource StatusErrorBrush}"
                                   FontSize="12" TextWrapping="Wrap"
                                   IsVisible="{Binding MediaError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <!-- Unknown server warning -->
                        <StackPanel Orientation="Horizontal" Spacing="4"
                                    IsVisible="{Binding IsUnknownServer}">
                            <PathIcon Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"
                                      Width="14" Height="14"
                                      Foreground="{DynamicResource StatusWarningBrush}" />
                            <TextBlock Text="{Binding ServerHostname, StringFormat='Unknown server: {0}'}"
                                       Foreground="{DynamicResource StatusWarningBrush}"
                                       FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Text Content (for non-image/non-audio messages) -->
                <TextBlock Text="{Binding Content}"
                           Foreground="{DynamicResource BubbleReceivedTextBrush}"
                           TextWrapping="Wrap" FontSize="14"
                           IsVisible="{Binding IsTextMessage}" />

                <!-- Emoji reaction picker + reply (hover) -->
                <StackPanel Orientation="Horizontal" Spacing="2"
                            IsVisible="{Binding IsHovering}"
                            HorizontalAlignment="Right" Margin="0,2,0,0">
                    <Button Content="↩" Classes="icon" Padding="4,2" FontSize="14"
                            ToolTip.Tip="Reply"
                            Tag="{Binding}"
                            Click="OnReplyClick" />
                    <Button Content="👍" Classes="icon" Padding="4,2" FontSize="14"
                            Command="{Binding ReactCommand}" CommandParameter="👍" />
                    <Button Content="❤️" Classes="icon" Padding="4,2" FontSize="14"
                            Command="{Binding ReactCommand}" CommandParameter="❤️" />
                    <Button Content="😂" Classes="icon" Padding="4,2" FontSize="14"
                            Command="{Binding ReactCommand}" CommandParameter="😂" />
                    <Button Content="😮" Classes="icon" Padding="4,2" FontSize="14"
                            Command="{Binding ReactCommand}" CommandParameter="😮" />
                    <Button Content="😢" Classes="icon" Padding="4,2" FontSize="14"
                            Command="{Binding ReactCommand}" CommandParameter="😢" />
                    <Button Content="🔥" Classes="icon" Padding="4,2" FontSize="14"
                            Command="{Binding ReactCommand}" CommandParameter="🔥" />
                </StackPanel>

                <!-- Timestamp -->
                <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11" HorizontalAlignment="Right" />

                <!-- Reactions -->
                <Border IsVisible="{Binding HasReactions}"
                        Background="{DynamicResource SurfaceSecondaryBrush}"
                        CornerRadius="10" Padding="6,2" Margin="0,2,0,0"
                        HorizontalAlignment="Left">
                    <TextBlock Text="{Binding ReactionsDisplay}"
                               FontSize="13" />
                </Border>
            </StackPanel>
        </Border>

        <!-- Sent Message (right aligned) -->
        <Border HorizontalAlignment="Right" MaxWidth="480"
                IsVisible="{Binding IsFromCurrentUser}"
                Background="{DynamicResource BubbleSentBrush}"
                BorderBrush="{DynamicResource BubbleSentBorderBrush}"
                BorderThickness="1.5"
                CornerRadius="16,16,4,16" Padding="12,8">
            <StackPanel Spacing="4">

                <!-- Reply quote -->
                <Border IsVisible="{Binding HasReplyTo}"
                        BorderBrush="{DynamicResource NostrPurpleBrush}" BorderThickness="2,0,0,0"
                        Padding="8,4" Margin="0,2" Background="{DynamicResource SurfaceSecondaryBrush}"
                        CornerRadius="0,4,4,0" Opacity="0.8">
                    <StackPanel Spacing="1">
                        <TextBlock Text="{Binding ReplyToSenderName}"
                                   Foreground="{DynamicResource NostrPurpleLightBrush}"
                                   FontSize="11" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ReplyToContent}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" TextTrimming="CharacterEllipsis" MaxLines="2" />
                    </StackPanel>
                </Border>

                <!-- Image Media Widget (for image messages) -->
                <Border IsVisible="{Binding IsImage}"
                        CornerRadius="8" Margin="0,2" ClipToBounds="True">
                    <StackPanel Spacing="4">

                        <!-- State 1: MIP-04 Disabled -->
                        <Border IsVisible="{Binding ShowMediaDisabled}"
                                Background="{DynamicResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Media loading disabled"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="13" FontStyle="Italic" />
                                <TextBlock Text="Enable in Settings > Privacy"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11" />
                            </StackPanel>
                        </Border>

                        <!-- State 2: Tap to Load -->
                        <Border IsVisible="{Binding ShowTapToLoad}"
                                Background="{DynamicResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="Auto,*">
                                    <PathIcon Grid.Column="0"
                                              Data="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"
                                              Width="18" Height="18" Margin="0,0,8,0"
                                              Foreground="{DynamicResource TextMutedBrush}"
                                              VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ImageDisplayText}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="13" FontStyle="Italic"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <Button Classes="secondary" Content="Tap to load"
                                        Command="{Binding LoadMediaCommand}"
                                        HorizontalAlignment="Left"
                                        Padding="12,4" FontSize="12" />
                                <TextBlock Text="(your IP will be visible to the host)"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="10" />
                                <!-- Unknown server warning -->
                                <StackPanel Orientation="Horizontal" Spacing="4"
                                            IsVisible="{Binding IsUnknownServer}">
                                    <PathIcon Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"
                                              Width="14" Height="14"
                                              Foreground="{DynamicResource StatusWarningBrush}" />
                                    <TextBlock Text="{Binding ServerHostname, StringFormat='Unknown server: {0}'}"
                                               Foreground="{DynamicResource StatusWarningBrush}"
                                               FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- State 3: Loading -->
                        <Border IsVisible="{Binding IsLoadingMedia}"
                                Background="{DynamicResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Loading..." Classes="muted" FontSize="13" />
                                <TextBlock Text="{Binding MediaSizeDisplay}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- State 4: Loaded (show image) -->
                        <Image IsVisible="{Binding IsMediaLoaded}"
                               Source="{Binding DecryptedMediaBytes, Converter={StaticResource BytesToBitmap}}"
                               MaxWidth="400" MaxHeight="400"
                               Stretch="Uniform"
                               HorizontalAlignment="Right" />

                        <!-- State 5: Error -->
                        <Border IsVisible="{Binding MediaError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Background="{DynamicResource SurfaceSecondaryBrush}"
                                CornerRadius="8" Padding="12,8">
                            <TextBlock Text="{Binding MediaError}"
                                       Foreground="{DynamicResource StatusErrorBrush}"
                                       FontSize="12" TextWrapping="Wrap" />
                        </Border>

                    </StackPanel>
                </Border>

                <!-- Audio Player (for voice messages) -->
                <StackPanel IsVisible="{Binding IsAudio}" Spacing="4">
                    <!-- Load button (before download) -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding ShowTapToLoad}">
                        <Button Command="{Binding LoadMediaCommand}"
                                Width="36" Height="36" CornerRadius="18"
                                Padding="0" Classes="primary">
                            <PathIcon Data="M8 5v14l11-7z" Width="16" Height="16" Foreground="White" />
                        </Button>
                        <TextBlock Text="{Binding ImageDisplayText}"
                                   VerticalAlignment="Center" FontSize="13" />
                    </StackPanel>

                    <!-- Mini audio player (after download/decode) -->
                    <Border IsVisible="{Binding IsMediaLoaded}"
                            Background="{DynamicResource SurfaceTertiaryBrush}"
                            CornerRadius="20" Padding="4,4,12,4"
                            Margin="0,4,0,0"
                            MinWidth="260" MaxWidth="320">
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <!-- Play/Pause button -->
                            <Button Grid.Column="0"
                                    Command="{Binding ToggleAudioCommand}"
                                    Width="36" Height="36" CornerRadius="18"
                                    Padding="0" Classes="primary" Margin="0,0,8,0">
                                <Panel>
                                    <PathIcon Data="M8 5v14l11-7z" Width="14" Height="14"
                                              Foreground="White"
                                              IsVisible="{Binding !IsPlayingAudio}" />
                                    <PathIcon Data="M6 19h4V5H6v14zm8-14v14h4V5h-4z" Width="14" Height="14"
                                              Foreground="White"
                                              IsVisible="{Binding IsPlayingAudio}" />
                                </Panel>
                            </Button>

                            <!-- Seekable progress slider -->
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="1"
                                    Value="{Binding AudioProgress}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0"
                                    PointerPressed="AudioSlider_PointerPressed"
                                    PointerReleased="AudioSlider_PointerReleased" />

                            <!-- Elapsed / Duration -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding AudioTimeDisplay}"
                                       VerticalAlignment="Center"
                                       FontSize="11" FontFamily="Consolas,monospace"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       MinWidth="70" TextAlignment="Right" />
                        </Grid>
                    </Border>

                    <!-- Disabled / Error states -->
                    <TextBlock Text="{Binding ImageDisplayText}"
                               FontSize="13"
                               Foreground="{DynamicResource TextMutedBrush}"
                               IsVisible="{Binding ShowMediaDisabled}" />
                    <TextBlock Text="{Binding MediaError}"
                               FontSize="13"
                               Foreground="{DynamicResource StatusErrorBrush}"
                               IsVisible="{Binding MediaError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>

                <!-- File Attachment (for file messages) -->
                <Border IsVisible="{Binding IsFile}"
                        Background="{DynamicResource SurfaceSecondaryBrush}"
                        CornerRadius="8" Padding="12,8" Margin="0,2">
                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="Auto,*">
                            <PathIcon Grid.Column="0"
                                      Data="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zM6 20V4h7v5h5v11H6z"
                                      Width="20" Height="20" Margin="0,0,10,0"
                                      Foreground="{DynamicResource TextMutedBrush}"
                                      VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="1">
                                <TextBlock Text="{Binding ImageDisplayText}"
                                           FontSize="13" TextWrapping="Wrap"
                                           Foreground="{DynamicResource BubbleSentTextBrush}" />
                            </StackPanel>
                        </Grid>
                        <Button Classes="secondary" Content="Download"
                                Command="{Binding LoadMediaCommand}"
                                HorizontalAlignment="Left"
                                Padding="12,4" FontSize="12"
                                IsVisible="{Binding ShowTapToLoad}" />
                        <TextBlock Text="Media loading disabled — enable in Settings"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11" FontStyle="Italic"
                                   IsVisible="{Binding ShowMediaDisabled}" />
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding IsLoadingMedia}">
                            <TextBlock Text="Downloading..." Classes="muted" FontSize="12" />
                            <TextBlock Text="{Binding MediaSizeDisplay}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="12" />
                        </StackPanel>
                        <TextBlock Text="Downloaded"
                                   FontSize="12" Foreground="{DynamicResource StatusOnlineBrush}"
                                   IsVisible="{Binding IsMediaLoaded}" />
                        <TextBlock Text="{Binding MediaError}"
                                   Foreground="{DynamicResource StatusErrorBrush}"
                                   FontSize="12" TextWrapping="Wrap"
                                   IsVisible="{Binding MediaError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                </Border>

                <!-- Text Content (for non-image/non-audio messages) -->
                <TextBlock Text="{Binding Content}"
                           Foreground="{DynamicResource BubbleSentTextBrush}"
                           TextWrapping="Wrap" FontSize="14"
                           IsVisible="{Binding IsTextMessage}" />

                <!-- Emoji reaction picker + reply (hover) -->
                <StackPanel Orientation="Horizontal" Spacing="2"
                            IsVisible="{Binding IsHovering}"
                            HorizontalAlignment="Right" Margin="0,2,0,0">
                    <Button Content="↩" Classes="icon" Padding="4,2" FontSize="14"
                            ToolTip.Tip="Reply"
                            Tag="{Binding}"
                            Click="OnReplyClick" />
                    <Button Content="👍" Classes="icon" Padding="4,2" FontSize="14"
                            Command="{Binding ReactCommand}" CommandParameter="👍" />
                    <Button Content="❤️" Classes="icon" Padding="4,2" FontSize="14"
                            Command="{Binding ReactCommand}" CommandParameter="❤️" />
                    <Button Content="😂" Classes="icon" Padding="4,2" FontSize="14"
                            Command="{Binding ReactCommand}" CommandParameter="😂" />
                    <Button Content="😮" Classes="icon" Padding="4,2" FontSize="14"
                            Command="{Binding ReactCommand}" CommandParameter="😮" />
                    <Button Content="😢" Classes="icon" Padding="4,2" FontSize="14"
                            Command="{Binding ReactCommand}" CommandParameter="😢" />
                    <Button Content="🔥" Classes="icon" Padding="4,2" FontSize="14"
                            Command="{Binding ReactCommand}" CommandParameter="🔥" />
                </StackPanel>

                <!-- Timestamp -->
                <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}"
                           Foreground="{DynamicResource NostrPurpleAccentBrush}"
                           FontSize="11" HorizontalAlignment="Right" Opacity="0.8" />

                <!-- Reactions -->
                <Border IsVisible="{Binding HasReactions}"
                        Background="{DynamicResource SurfaceSecondaryBrush}"
                        CornerRadius="10" Padding="6,2" Margin="0,2,0,0"
                        HorizontalAlignment="Right">
                    <TextBlock Text="{Binding ReactionsDisplay}"
                               FontSize="13" />
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

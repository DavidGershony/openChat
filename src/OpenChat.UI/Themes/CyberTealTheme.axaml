<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Cyber Teal Theme — Cypherpunk aesthetic, cyan/teal on dark -->

    <!-- Primary Colors - Teal/Cyan -->
    <Color x:Key="NostrPurple">#06B6D4</Color>
    <Color x:Key="NostrPurpleLight">#22D3EE</Color>
    <Color x:Key="NostrPurpleDark">#0891B2</Color>
    <Color x:Key="NostrPurpleAccent">#67E8F9</Color>

    <!-- Background Colors - Dark Slate -->
    <Color x:Key="BackgroundDark">#0B1215</Color>
    <Color x:Key="BackgroundMedium">#121E24</Color>
    <Color x:Key="BackgroundLight">#1A2B33</Color>
    <Color x:Key="BackgroundCard">#1E3340</Color>

    <!-- Surface Colors -->
    <Color x:Key="SurfacePrimary">#142028</Color>
    <Color x:Key="SurfaceSecondary">#1A2B33</Color>
    <Color x:Key="SurfaceTertiary">#243B47</Color>
    <Color x:Key="SurfaceHover">#2A4452</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#E0F2F1</Color>
    <Color x:Key="TextSecondary">#80CBC4</Color>
    <Color x:Key="TextMuted">#5C9A95</Color>

    <!-- Message Bubble Colors -->
    <Color x:Key="BubbleSent">#0E4D5C</Color>
    <Color x:Key="BubbleReceived">#1E3340</Color>
    <Color x:Key="BubbleSentText">#E0F7FA</Color>
    <Color x:Key="BubbleReceivedText">#E0F2F1</Color>

    <!-- Status Colors -->
    <Color x:Key="StatusOnline">#10B981</Color>
    <Color x:Key="StatusOffline">#5C7A80</Color>
    <Color x:Key="StatusError">#EF4444</Color>
    <Color x:Key="StatusWarning">#FBBF24</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderDefault">#2A4452</Color>
    <Color x:Key="BorderFocused">#06B6D4</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="NostrPurpleBrush" Color="{StaticResource NostrPurple}" />
    <SolidColorBrush x:Key="NostrPurpleLightBrush" Color="{StaticResource NostrPurpleLight}" />
    <SolidColorBrush x:Key="NostrPurpleDarkBrush" Color="{StaticResource NostrPurpleDark}" />
    <SolidColorBrush x:Key="NostrPurpleAccentBrush" Color="{StaticResource NostrPurpleAccent}" />

    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource BackgroundDark}" />
    <SolidColorBrush x:Key="BackgroundMediumBrush" Color="{StaticResource BackgroundMedium}" />
    <SolidColorBrush x:Key="BackgroundLightBrush" Color="{StaticResource BackgroundLight}" />
    <SolidColorBrush x:Key="BackgroundCardBrush" Color="{StaticResource BackgroundCard}" />

    <SolidColorBrush x:Key="SurfacePrimaryBrush" Color="{StaticResource SurfacePrimary}" />
    <SolidColorBrush x:Key="SurfaceSecondaryBrush" Color="{StaticResource SurfaceSecondary}" />
    <SolidColorBrush x:Key="SurfaceTertiaryBrush" Color="{StaticResource SurfaceTertiary}" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHover}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />

    <SolidColorBrush x:Key="BubbleSentBrush" Color="{StaticResource BubbleSent}" />
    <SolidColorBrush x:Key="BubbleReceivedBrush" Color="{StaticResource BubbleReceived}" />
    <SolidColorBrush x:Key="BubbleSentTextBrush" Color="{StaticResource BubbleSentText}" />
    <SolidColorBrush x:Key="BubbleReceivedTextBrush" Color="{StaticResource BubbleReceivedText}" />

    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefault}" />
    <SolidColorBrush x:Key="BorderFocusedBrush" Color="{StaticResource BorderFocused}" />

    <SolidColorBrush x:Key="StatusOnlineBrush" Color="{StaticResource StatusOnline}" />
    <SolidColorBrush x:Key="StatusErrorBrush" Color="{StaticResource StatusError}" />
    <SolidColorBrush x:Key="StatusWarningBrush" Color="{StaticResource StatusWarning}" />
    <SolidColorBrush x:Key="StatusOfflineBrush" Color="{StaticResource StatusOffline}" />

    <!-- Sent bubble border -->
    <SolidColorBrush x:Key="BubbleSentBorderBrush" Color="{StaticResource NostrPurple}" />

    <!-- Selected item -->
    <SolidColorBrush x:Key="SelectedItemBgBrush" Color="{StaticResource BackgroundMedium}" />
    <SolidColorBrush x:Key="SelectedItemBorderBrush" Color="{StaticResource NostrPurple}" />

    <!-- Semi-transparent themed backgrounds -->
    <SolidColorBrush x:Key="ErrorBgBrush" Color="#3DEF4444" />
    <SolidColorBrush x:Key="WarningBgBrush" Color="#3DFBBF24" />
    <SolidColorBrush x:Key="AccentBgBrush" Color="#3D06B6D4" />
    <SolidColorBrush x:Key="UploadBannerBrush" Color="#142028" />
    <SolidColorBrush x:Key="UploadBannerBorderBrush" Color="#06B6D4" />
    <SolidColorBrush x:Key="DangerButtonBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="WarningTextBrush" Color="#FBBF24" />
    <SolidColorBrush x:Key="ResetButtonBrush" Color="#0891B2" />

</ResourceDictionary>

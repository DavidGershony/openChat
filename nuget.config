<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!--
      Microsoft's public feed for .NET runtime/SDK packages that haven't been
      promoted to nuget.org yet. Needed because the .NET 10 Android workload
      manifest references Microsoft.NETCore.App.Runtime.Mono.{linux,win,osx}-x64
      v10.0.x packages, but these are only published here — latest version on
      nuget.org is 9.0.0-preview.7. Without this feed, `dotnet publish` of any
      net10.0-android project fails on CI with NU1102.

      Revisit / remove once Microsoft publishes the .NET 10 Mono runtime packs
      to nuget.org.
    -->
    <add key="dotnet-public" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-public/nuget/v3/index.json" />
  </packageSources>
</configuration>
